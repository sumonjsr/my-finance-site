---
import Layout from '../layouts/Layout.astro';
import calculators from '../../calculators.json'; 

const title = "QuickFinCalc Pro | Professional Financial Tools";
const description = "Free online financial tools for ROI, Loans, Taxes, and Business Margins.";
---

<Layout title={title} description={description}>
    <style>
        :root {
            --primary: #1e3a8a;
            --secondary: #d4a373;
            --accent: #f8fafc;
            --text-dark: #1e293b;
            --text-light: #64748b;
            --border: #e2e8f0;
        }

        .hero {
            background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
            padding: 100px 20px;
            text-align: center;
            color: white;
        }

        .hero h1 {
            font-size: 3.2rem;
            font-weight: 800;
            margin-bottom: 20px;
            font-family: 'Crimson Pro', serif;
        }

        .search-container {
            max-width: 650px;
            margin: 0 auto;
        }

        #searchInput {
            width: 100%;
            padding: 22px 35px;
            border-radius: 16px;
            border: none;
            font-size: 1.15rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            background: white;
            color: var(--text-dark);
        }

        .container {
            max-width: 1200px;
            margin: -50px auto 80px;
            padding: 0 20px;
        }

        .calc-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
        }

        .calc-card {
            background: white;
            padding: 35px;
            border-radius: 24px;
            border: 1px solid var(--border);
            text-decoration: none;
            display: flex;
            flex-direction: column;
            transition: all 0.4s ease;
            min-height: 200px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .calc-card:hover {
            transform: translateY(-12px);
            border-color: var(--secondary);
            box-shadow: 0 25px 50px rgba(30, 58, 138, 0.1);
        }

        .calc-card h3 {
            color: var(--primary);
            margin: 0 0 15px 0;
            font-size: 1.4rem;
            font-family: 'Crimson Pro', serif;
        }

        .calc-card p {
            color: var(--text-light);
            font-size: 1rem;
            line-height: 1.6;
            margin: 0;
        }

        .badge {
            display: inline-block;
            margin-top: auto;
            font-size: 0.75rem;
            font-weight: 700;
            color: var(--primary);
            background: #e0e7ff;
            padding: 5px 12px;
            border-radius: 6px;
            width: fit-content;
        }
    </style>

    <section class="hero">
        <div class="search-container">
            <h1>Precision Financial Tools</h1>
            <input 
                type="text" 
                id="searchInput" 
                placeholder="Search tools (e.g. ROI, Loan...)" 
                onkeyup="filterCalculators()" 
            />
        </div>
    </section>

    <main class="container">
        <div class="calc-grid" id="calcGrid">
            {calculators.map((calc) => (
                <a href={`/calculator/${calc.slug}`} class="calc-card" data-name={calc.name.toLowerCase()}>
                    <h3>{calc.name}</h3>
                    <p>{calc.description}</p>
                    <span class="badge">Tool</span>
                </a>
            ))}
        </div>
    </main>

    <script is:inline>
        function filterCalculators() {
            const filter = document.getElementById('searchInput').value.toLowerCase();
            const cards = document.getElementsByClassName('calc-card');
            for (let i = 0; i < cards.length; i++) {
                const name = cards[i].getAttribute('data-name');
                cards[i].style.display = name.includes(filter) ? "flex" : "none";
            }
        }
    </script>
</Layout>