---
// Simple ROI Calculator for your site
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Finance Calculator Hub</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f0f2f5; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .calc-card { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 350px; }
        h1 { color: #1a73e8; font-size: 24px; margin-bottom: 20px; text-align: center; }
        label { display: block; margin-bottom: 5px; font-weight: 600; color: #555; }
        input { width: 100%; padding: 10px; margin-bottom: 15px; border: 1px solid #ddd; border-radius: 6px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background-color: #1a73e8; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 16px; transition: background 0.3s; }
        button:hover { background-color: #1557b0; }
        #result { margin-top: 20px; padding: 10px; background: #e8f0fe; border-radius: 6px; text-align: center; font-weight: bold; color: #1a73e8; display: none; }
    </style>
</head>
<body>
    <div class="calc-card">
        <h1>ROI Calculator</h1>
        <label>Investment Amount ($)</label>
        <input type="number" id="invest" placeholder="e.g. 1000">
        <label>Total Return ($)</label>
        <input type="number" id="return" placeholder="e.g. 1200">
        <button onclick="calculate()">Calculate ROI</button>
        <div id="result"></div>
    </div>

    <script is:inline>
        function calculate() {
            const i = document.getElementById('invest').value;
            const r = document.getElementById('return').value;
            if(i > 0) {
                const roi = ((r - i) / i) * 100;
                const resDiv = document.getElementById('result');
                resDiv.style.display = 'block';
                resDiv.innerText = "Your ROI is: " + roi.toFixed(2) + "%";
            }
        }
    </script>
</body>
</html>
