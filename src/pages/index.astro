    <script is:inline>
        function filterCalculators() {
            const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
            const blocks = document.querySelectorAll('.category-block');

            blocks.forEach(block => {
                const items = block.querySelectorAll('.calc-list-item');
                let blockMatch = false;

                items.forEach(item => {
                    const name = item.querySelector('.calc-list-name').textContent.toLowerCase();
                    const desc = item.querySelector('.calc-list-desc').textContent.toLowerCase();
                    const match = searchTerm === '' || name.includes(searchTerm) || desc.includes(searchTerm);
                    item.style.display = match ? 'flex' : 'none';
                    if (match) blockMatch = true;
                });

                block.style.display = searchTerm === '' || blockMatch ? 'block' : 'none';
            });

            if (searchTerm !== '') {
                const section = document.getElementById('calculatorsSection');
                if (section) setTimeout(() => section.scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
            }
        }
    </script>
