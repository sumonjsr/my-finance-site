---
import Layout from '../layouts/Layout.astro';
import calculators from '../../calculators.json'; // আপনার পাথ অনুযায়ী চেক করে নিন

const title = "FinanceHub Pro | 50+ Professional Financial Calculators";
const description = "Free online financial tools for ROI, Loans, Taxes, and Business Margins. Accurate, private, and easy to use.";
---

<Layout title={title} description={description}>
    <style>
        :root {
            --primary: #1e3a8a;
            --secondary: #2563eb;
            --accent: #f0f9ff;
            --text-dark: #1e293b;
            --text-light: #64748b;
            --border: #e2e8f0;
        }

        /* Hero Search Area */
        .hero {
            background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
            padding: 80px 20px;
            text-align: center;
            color: white;
        }

        .hero h1 {
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 20px;
            letter-spacing: -0.02em;
        }

        .search-container {
            max-width: 650px;
            margin: 0 auto;
            position: relative;
        }

        #searchInput {
            width: 100%;
            padding: 20px 30px;
            border-radius: 50px;
            border: none;
            font-size: 1.1rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            outline: 2px solid transparent;
            transition: 0.3s;
        }

        #searchInput:focus {
            outline-color: var(--accent);
            transform: scale(1.02);
        }

        /* Main Grid */
        .container {
            max-width: 1200px;
            margin: -40px auto 80px;
            padding: 0 20px;
        }

        .calc-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
        }

        .calc-card {
            background: white;
            padding: 32px;
            border-radius: 20px;
            border: 1px solid var(--border);
            text-decoration: none;
            display: flex;
            flex-direction: column;
            justify-content: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            min-height: 180px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .calc-card:hover {
            transform: translateY(-10px);
            border-color: var(--secondary);
            box-shadow: 0 20px 40px rgba(30, 58, 138, 0.1);
        }

        .calc-card h3 {
            color: var(--primary);
            margin: 0 0 12px 0;
            font-size: 1.25rem;
            font-weight: 700;
        }

        .calc-card p {
            color: var(--text-light);
            font-size: 0.95rem;
            line-height: 1.6;
            margin: 0;
        }

        /* Badges for Categories (Optional Idea) */
        .badge {
            display: inline-block;
            margin-top: 15px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--secondary);
            background: var(--accent);
            padding: 4px 10px;
            border-radius: 4px;
            width: fit-content;
        }

        @media (max-width: 640px) {
            .hero h1 { font-size: 2rem; }
            .calc-card { padding: 24px; }
        }
    </style>

    <section class="hero">
        <div class="search-container">
            <h1>Expert Financial Planning</h1>
            <p style="margin-bottom: 25px; opacity: 0.9;">Choose from over 50+ professional tools for accurate calculations.</p>
            <input 
                type="text" 
                id="searchInput" 
                placeholder="Search calculators (e.g. ROI, Mortgage, GST...)" 
                onkeyup="filterCalculators()" 
                autocomplete="off"
            />
        </div>
    </section>

    <main class="container">
        <div class="calc-grid" id="calcGrid">
            {calculators.map((calc) => (
                <a href={`/${calc.slug}/`} class="calc-card" data-name={calc.name.toLowerCase()} data-desc={calc.description.toLowerCase()}>
                    <h3>{calc.name}</h3>
                    <p>{calc.description}</p>
                    <span class="badge">Tool</span>
                </a>
            ))}
        </div>
        
        <div id="noResults" style="display: none; text-align: center; padding: 50px; color: var(--text-light);">
            <p>No calculators found. Try searching with different keywords.</p>
        </div>
    </main>

    <script is:inline>
        function filterCalculators() {
            const filter = document.getElementById('searchInput').value.toLowerCase();
            const cards = document.getElementsByClassName('calc-card');
            const noResults = document.getElementById('noResults');
            let found = false;

            for (let i = 0; i < cards.length; i++) {
                const name = cards[i].getAttribute('data-name');
                const desc = cards[i].getAttribute('data-desc');
                
                if (name.includes(filter) || desc.includes(filter)) {
                    cards[i].style.display = "flex";
                    found = true;
                } else {
                    cards[i].style.display = "none";
                }
            }

            noResults.style.display = found ? "none" : "block";
        }
    </script>
</Layout>