---
// Professional Layout and Multi-Calculator Setup
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>FinanceHub - Expert Calculators</title>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; margin: 0; color: #1e293b; }
        nav { background: #1e40af; padding: 1rem; color: white; text-align: center; font-weight: bold; font-size: 1.2rem; }
        .container { max-width: 800px; margin: 40px auto; padding: 0 20px; }
        .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border: 1px solid #e2e8f0; }
        h1 { color: #1e3a8a; text-align: center; margin-bottom: 30px; }
        h2 { font-size: 1.1rem; margin-top: 0; color: #334155; }
        label { display: block; margin: 10px 0 5px; font-size: 0.9rem; font-weight: 600; }
        input { width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; box-sizing: border-box; }
        button { width: 100%; padding: 12px; background: #2563eb; color: white; border: none; border-radius: 6px; margin-top: 15px; cursor: pointer; font-weight: bold; transition: 0.2s; }
        button:hover { background: #1d4ed8; }
        .result-box { margin-top: 15px; padding: 12px; background: #f0f9ff; border-radius: 6px; color: #0369a1; font-weight: bold; text-align: center; display: none; }
    </style>
</head>
<body>
    <nav>FinanceHub.bd</nav>
    <div class="container">
        <h1>Financial Decision Tools</h1>
        
        <div class="grid">
            <div class="card">
                <h2>ROI Calculator</h2>
                <label>Investment ($)</label>
                <input type="number" id="roi-inv" placeholder="1000">
                <label>Total Return ($)</label>
                <input type="number" id="roi-ret" placeholder="1200">
                <button onclick="calcROI()">Calculate ROI</button>
                <div id="roi-res" class="result-box"></div>
            </div>

            <div class="card">
                <h2>Compound Interest</h2>
                <label>Principal ($)</label>
                <input type="number" id="ci-p" placeholder="1000">
                <label>Annual Rate (%)</label>
                <input type="number" id="ci-r" placeholder="5">
                <label>Years</label>
                <input type="number" id="ci-t" placeholder="5">
                <button onclick="calcCI()">Calculate</button>
                <div id="ci-res" class="result-box"></div>
            </div>
        </div>
    </div>

    <script is:inline>
        function calcROI() {
            const i = document.getElementById('roi-inv').value;
            const r = document.getElementById('roi-ret').value;
            const res = document.getElementById('roi-res');
            if(i > 0) {
                const val = ((r - i) / i) * 100;
                res.style.display = 'block';
                res.innerText = `ROI: ${val.toFixed(2)}%`;
            }
        }

        function calcCI() {
            const p = parseFloat(document.getElementById('ci-p').value);
            const r = parseFloat(document.getElementById('ci-r').value) / 100;
            const t = parseFloat(document.getElementById('ci-t').value);
            const res = document.getElementById('ci-res');
            if(p > 0) {
                const amount = p * Math.pow((1 + r), t);
                res.style.display = 'block';
                res.innerText = `Total: $${amount.toFixed(2)}`;
            }
        }
    </script>
</body>
</html>
