---
import calculators from '../calculators.json';
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>FinanceHub - Expert Calculators</title>
    <style>
        body { font-family: 'Inter', sans-serif; background: #f8fafc; margin: 0; padding: 0; }
        .nav { background: #1e40af; color: white; padding: 20px; text-align: center; font-weight: bold; font-size: 1.5rem; }
        .container { max-width: 1000px; margin: 40px auto; padding: 0 20px; }
        .header-text { text-align: center; color: #1e3a8a; margin-bottom: 40px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 25px; }
        .calc-card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; text-decoration: none; color: inherit; transition: 0.3s; display: flex; flex-direction: column; justify-content: space-between; }
        .calc-card:hover { transform: translateY(-5px); border-color: #2563eb; box-shadow: 0 10px 15px rgba(0,0,0,0.1); }
        h2 { margin: 0 0 10px 0; color: #1e3a8a; font-size: 1.3rem; }
        p { font-size: 0.95rem; color: #64748b; line-height: 1.5; margin-bottom: 20px; }
        .btn-link { color: #2563eb; font-weight: bold; font-size: 0.9rem; display: flex; align-items: center; }
    </style>
</head>
<body>
    <div class="nav">FinanceHub.bd</div>
    <div class="container">
        <div class="header-text">
            <h1>Financial Decision Tools</h1>
            <p>Access our wide range of professional calculators for your business and personal needs.</p>
        </div>
        <div class="grid">
            {calculators.map((calc) => (
                <a href={`/${calc.slug}`} class="calc-card">
                    <div>
                        <h2>{calc.name}</h2>
                        <p>{calc.description}</p>
                    </div>
                    <div class="btn-link">Open Calculator →</div>
                </a>
            ))}
        </div>
    </div>
</body>
</html>