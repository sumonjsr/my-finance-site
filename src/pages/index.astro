---
import Layout from '../layouts/Layout.astro';
import calculators from '../../calculators.json';

const title = "Financial Calculators | EMI, ROI & Tax Tools";
const description = "Calculate loan EMI, ROI, taxes & profit margins instantly. Free professional tools for businesses & investors. Accurate results in seconds—no signup.";

// FIX 1: Explicit canonical for homepage — prevents /index.html canonical bug
const canonical = "https://quickfincalc.com/";

// Group calculators by type
const calcsByType = {};
calculators.forEach(calc => {
  if (!calcsByType[calc.type]) {
    calcsByType[calc.type] = [];
  }
  calcsByType[calc.type].push(calc);
});

// Category descriptions
const categoryInfo = {
  'loan': {
    emoji: '💰',
    title: 'Loans & EMI',
    description: 'Calculate loan payments, EMI, mortgage, auto loans, and personal loans with accurate interest calculations.',
    color: '#3b82f6'
  },
  'investment': {
    emoji: '📈',
    title: 'Investments & Returns',
    description: 'SIP, Analyze ROI, dividend yields, compound interest, stock profits, and investment performance.',
    color: '#10b981'
  },
  'tax': {
    emoji: '📊',
    title: 'Taxes & Compliance',
    description: 'Calculate sales tax, VAT, GST, payroll taxes, and self-employment tax for compliance.',
    color: '#f59e0b'
  },
  'ecommerce': {
    emoji: '🛍️',
    title: 'E-commerce & Margins',
    description: 'Optimize profit margins, calculate Amazon FBA fees, eBay fees, and business profitability.',
    color: '#8b5cf6'
  },
  'marketing': {
    emoji: '📢',
    title: 'Marketing & Metrics',
    description: 'Track CAC, CLV, email ROI, retention rates, and marketing efficiency metrics.',
    color: '#ec4899'
  },
  'salary': {
    emoji: '💼',
    title: 'Salary & HR',
    description: 'Calculate hourly rates, payroll taxes, turnover costs, and employee metrics.',
    color: '#06b6d4'
  }
};
---

<Layout title={title} description={description} canonical={canonical}>
    <style>
        :root {
            --primary: #1e3a8a;
            --secondary: #d4a373;
            --accent: #f8fafc;
            --text-dark: #1e293b;
            --text-light: #64748b;
            --border: #e2e8f0;
        }

        /* HERO SECTION */
        .hero {
            background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
            padding: 60px 20px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 20% 50%, rgba(212, 163, 115, 0.1) 0%, transparent 50%),
                        radial-gradient(circle at 80% 80%, rgba(212, 163, 115, 0.05) 0%, transparent 50%);
            pointer-events: none;
        }

        .hero-content {
            position: relative;
            z-index: 2;
        }

        .hero h1 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 12px;
            font-family: 'Crimson Pro', serif;
        }

        .hero p {
            font-size: 1rem;
            opacity: 0.95;
            margin-bottom: 25px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .search-container {
            max-width: 650px;
            margin: 0 auto;
        }

        #searchInput {
            width: 100%;
            padding: 16px 28px;
            border-radius: 16px;
            border: none;
            font-size: 1rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            background: white;
            color: var(--text-dark);
            transition: box-shadow 0.3s;
        }

        #searchInput:focus {
            outline: none;
            box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        }

        .main-container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* WHY QUICKFINCALC SECTION */
        .why-section {
            background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
            padding: 40px 20px;
            margin: -50px auto 80px;
            border-radius: 12px;
            border-left: 4px solid var(--primary);
            max-width: 1000px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }

        .why-section h2 {
            color: var(--primary);
            font-size: 1.8rem;
            font-family: 'Crimson Pro', serif;
            margin-bottom: 20px;
            font-weight: 700;
        }

        .why-section p {
            color: #334155;
            line-height: 1.8;
            margin-bottom: 15px;
            font-size: 1rem;
        }

        .why-section p:last-of-type {
            margin-bottom: 0;
        }

        /* FIX 4: Honest stats — real numbers only */
        .quick-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .stat-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 15px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .stat-number {
            font-size: 24px;
            font-weight: bold;
            color: var(--primary);
        }

        .stat-label {
            color: #64748b;
            font-size: 13px;
            margin-top: 5px;
            text-align: center;
        }

        /* HOW IT WORKS SECTION */
        .how-it-works {
            padding: 60px 20px;
            background: #f8fafc;
            margin: 60px 0;
            border-radius: 12px;
        }

        .how-it-works h2 {
            text-align: center;
            color: var(--primary);
            font-size: 1.8rem;
            font-family: 'Crimson Pro', serif;
            margin-bottom: 50px;
            font-weight: 700;
        }

        .steps-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }

        .step {
            flex: 1;
            min-width: 200px;
            text-align: center;
            padding: 20px;
        }

        .step-number {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 50px;
            height: 50px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .step h3 {
            color: var(--primary);
            font-size: 1rem;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .step p {
            color: #64748b;
            line-height: 1.6;
            font-size: 0.9rem;
        }

        .step-arrow {
            color: var(--primary);
            font-size: 28px;
            font-weight: bold;
            margin: 0 10px;
        }

        /* FIX 4: User metrics section — honest numbers */
        .user-metrics {
            padding: 60px 20px;
            background: white;
            margin: 60px 0;
            border-radius: 12px;
        }

        .user-metrics h2 {
            text-align: center;
            color: var(--primary);
            font-size: 1.8rem;
            font-family: 'Crimson Pro', serif;
            margin-bottom: 50px;
            font-weight: 700;
        }

        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 30px;
        }

        .metric-card {
            text-align: center;
            padding: 30px 20px;
            background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
        }

        .metric-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(30, 58, 138, 0.15);
            border-color: var(--primary);
        }

        .metric-number {
            font-size: 36px;
            font-weight: 800;
            color: var(--primary);
            margin-bottom: 10px;
        }

        .metric-label {
            font-size: 14px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .metric-description {
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.6;
            margin: 0;
        }

        /* FIX 5: Use cases section replacing fake testimonials */
        .usecases-section {
            padding: 60px 20px;
            background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
            margin: 60px 0;
            border-radius: 12px;
        }

        .usecases-section h2 {
            text-align: center;
            color: var(--primary);
            font-size: 1.8rem;
            font-family: 'Crimson Pro', serif;
            margin-bottom: 15px;
            font-weight: 700;
        }

        .usecases-subtitle {
            text-align: center;
            color: #64748b;
            font-size: 1rem;
            margin-bottom: 50px;
        }

        .usecases-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        .usecase-card {
            background: white;
            padding: 28px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }

        .usecase-card:hover {
            box-shadow: 0 12px 24px rgba(30, 58, 138, 0.12);
            transform: translateY(-6px);
            border-color: var(--primary);
        }

        .usecase-icon {
            font-size: 2.2rem;
            margin-bottom: 14px;
            display: block;
        }

        .usecase-card h3 {
            color: var(--primary);
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .usecase-card p {
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.6;
            margin: 0;
        }

        /* SECURITY BADGES */
        .security-badges {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 20px;
            margin-top: 50px;
            padding-top: 30px;
            border-top: 1px solid rgba(0, 0, 0, 0.1);
        }

        .badge {
            text-align: center;
            padding: 20px;
            background: white;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
        }

        .badge:hover {
            background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
            transform: translateY(-4px);
            border-color: var(--primary);
        }

        .badge-icon {
            font-size: 32px;
            margin-bottom: 10px;
            display: block;
        }

        .badge-text {
            color: var(--primary);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* TRUST & SECURITY SECTION */
        .trust-security {
            background: linear-gradient(135deg, #f0f9ff 0%, #f0fdf4 100%);
            padding: 50px 20px;
            margin: 60px 0 0 0;
            border-radius: 12px;
        }

        .trust-security h2 {
            text-align: center;
            color: var(--primary);
            font-size: 1.8rem;
            font-family: 'Crimson Pro', serif;
            margin-bottom: 40px;
            font-weight: 700;
        }

        .trust-features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 30px;
        }

        .trust-item {
            text-align: center;
            padding: 25px;
            background: white;
            border-radius: 10px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }

        .trust-icon {
            font-size: 40px;
            display: block;
            margin-bottom: 15px;
        }

        .trust-item h3 {
            color: var(--primary);
            font-size: 1rem;
            margin-bottom: 10px;
            font-weight: 600;
        }

        .trust-item p {
            color: #64748b;
            font-size: 0.9rem;
            line-height: 1.6;
        }

        /* AUTHOR BIO SECTION */
        .author-bio {
            background: linear-gradient(135deg, #1e3a8a 0%, #3730a3 100%);
            padding: 60px 20px;
            margin: 60px 0 40px 0;
            border-radius: 12px;
            color: white;
        }

        .bio-container {
            display: grid;
            grid-template-columns: 200px 1fr;
            gap: 40px;
            align-items: center;
            max-width: 900px;
            margin: 0 auto;
        }

        .bio-image {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .bio-photo {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid rgba(255, 255, 255, 0.3);
        }

        .placeholder-avatar {
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            font-weight: bold;
            border: 3px solid rgba(255, 255, 255, 0.3);
        }

        .bio-content h3 {
            color: rgba(255, 255, 255, 0.8);
            font-size: 12px;
            text-transform: uppercase;
            margin-bottom: 5px;
            font-weight: 500;
        }

        .bio-content h4 {
            color: white;
            font-size: 28px;
            margin-bottom: 5px;
            font-family: 'Crimson Pro', serif;
            font-weight: 600;
        }

        .bio-title {
            color: #93c5fd;
            font-size: 16px;
            font-weight: 500;
            margin-bottom: 20px;
        }

        .bio-content p {
            line-height: 1.8;
            color: rgba(255, 255, 255, 0.9);
            margin-bottom: 15px;
            font-size: 0.95rem;
        }

        .credentials {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin: 20px 0;
            padding: 20px 0;
            border-top: 1px solid rgba(255, 255, 255, 0.2);
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
        }

        .credential {
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.95rem;
        }

        .connect-text {
            font-size: 0.9rem;
            margin-bottom: 12px;
        }

        .social-links {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .social-link {
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.2);
            color: white;
            text-decoration: none;
            border-radius: 6px;
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.3);
            font-size: 0.9rem;
            font-weight: 500;
        }

        .social-link:hover {
            background: rgba(255, 255, 255, 0.3);
            border-color: rgba(255, 255, 255, 0.6);
        }

        /* CALCULATORS BY CATEGORY — Option C */
        .calculators-section {
            margin-bottom: 80px;
        }

        .section-title {
            text-align: center;
            color: var(--primary);
            font-size: 2.2rem;
            font-family: 'Crimson Pro', serif;
            font-weight: 800;
            margin-bottom: 50px;
        }

        .category-block {
            margin-bottom: 55px;
        }

        .category-block-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 3px solid var(--cat-color, var(--secondary));
        }

        .category-block-emoji { font-size: 1.8rem; }

        .category-block-title {
            color: var(--primary);
            font-size: 1.4rem;
            font-weight: 800;
            font-family: 'Crimson Pro', serif;
            margin: 0;
            flex: 1;
        }

        .category-block-count {
            background: #f1f5f9;
            color: var(--primary);
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 700;
        }

        .category-block-desc {
            color: var(--text-light);
            font-size: 0.9rem;
            margin-bottom: 16px;
            line-height: 1.6;
        }

        .calc-list-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 10px;
        }

        .calc-list-item {
            display: flex;
            align-items: center;
            gap: 10px;
            background: white;
            border: 1px solid var(--border);
            border-left: 3px solid var(--cat-color, var(--secondary));
            border-radius: 8px;
            padding: 12px 14px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .calc-list-item:hover {
            background: #f8fafc;
            box-shadow: 0 4px 12px rgba(30,58,138,0.09);
            transform: translateX(4px);
        }

        .calc-list-info { flex: 1; min-width: 0; }

        .calc-list-name {
            color: var(--primary);
            font-size: 0.88rem;
            font-weight: 600;
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .calc-list-desc {
            color: var(--text-light);
            font-size: 0.76rem;
            display: block;
            margin-top: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .calc-list-arrow {
            color: var(--cat-color, var(--secondary));
            font-size: 0.9rem;
            flex-shrink: 0;
        }

        /* CTA SECTION */
        .cta-section {
            background: linear-gradient(135deg, var(--primary) 0%, #0f172a 100%);
            color: white;
            padding: 60px 40px;
            text-align: center;
            border-radius: 20px;
            margin-top: 80px;
        }

        .cta-section h2 {
            font-family: 'Crimson Pro', serif;
            font-size: 2.2rem;
            margin-bottom: 15px;
        }

        .cta-section p {
            font-size: 1.1rem;
            opacity: 0.95;
            margin-bottom: 30px;
            text-align: center;
        }

        .cta-button {
            display: inline-block;
            padding: 14px 35px;
            background: var(--secondary);
            color: var(--primary);
            text-decoration: none;
            font-weight: 800;
            border-radius: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            font-size: 0.95rem;
            cursor: pointer;
            border: none;
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(212, 163, 115, 0.4);
        }


        /* RESPONSIVE */
        @media (max-width: 1024px) {
            .bio-container { grid-template-columns: 1fr; gap: 30px; }
            .steps-container { flex-direction: column; }
            .step-arrow { transform: rotate(90deg); margin: 10px 0; }
            .metrics-grid { grid-template-columns: repeat(2, 1fr); }
            .usecases-grid { grid-template-columns: 1fr; }
            .security-badges { grid-template-columns: repeat(2, 1fr); }
            .calc-list-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 1.8rem; }
            .section-title { font-size: 1.8rem; margin-bottom: 30px; }
            .cta-section { padding: 40px 20px; }
            .cta-section h2 { font-size: 1.6rem; }
            .why-section { padding: 30px 20px; margin: -30px auto 60px; }
            .why-section h2 { font-size: 1.4rem; }
            .quick-stats { grid-template-columns: repeat(2, 1fr); }
            .benefits-section h2 { font-size: 1.4rem; }
            .benefits-container { grid-template-columns: 1fr; }
            .how-it-works { padding: 40px 20px; }
            .how-it-works h2 { font-size: 1.4rem; }
            .trust-security { padding: 40px 20px; }
            .trust-security h2 { font-size: 1.4rem; }
            .author-bio { padding: 40px 20px; }
            .bio-container { grid-template-columns: 1fr; }
            .bio-content h4 { font-size: 22px; }
            .user-metrics h2, .usecases-section h2 { font-size: 1.4rem; }
            .metric-number { font-size: 28px; }
            .metrics-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
            .security-badges { grid-template-columns: repeat(2, 1fr); }
            .calc-list-grid { grid-template-columns: 1fr; }
            .category-block-title { font-size: 1.2rem; }
        }
    </style>

    <section class="hero">
        <div class="hero-content">
            <!-- FIX 8: More natural H1 -->
            <h1>Free Financial Calculators for Small Business, Loans & Investments</h1>
            <p>Professional-grade calculators for accurate financial planning, completely free</p>
            <div class="search-container">
                <input 
                    type="text" 
                    id="searchInput" 
                    placeholder="Search tools (e.g. ROI, Loan, Tax...)" 
                    onkeyup="filterCalculators()" 
                />
            </div>
        </div>
    </section>

    <div class="main-container">

        <!-- CALCULATORS BY CATEGORY — Option C: Full list per category -->
        <div class="calculators-section" id="calculatorsSection">
            <h2 class="section-title">Browse All Calculators by Category</h2>

            {Object.entries(calcsByType).map(([type, calcs]) => {
                const info = categoryInfo[type] || { title: type, emoji: '📊', description: 'Financial calculators', color: '#d4a373' };
                return (
                    <div class="category-block" style={`--cat-color: ${info.color}`}>
                        <div class="category-block-header">
                            <span class="category-block-emoji">{info.emoji}</span>
                            <h3 class="category-block-title">{info.title}</h3>
                            <span class="category-block-count">{calcs.length} Tools</span>
                        </div>
                        <p class="category-block-desc">{info.description}</p>
                        <div class="calc-list-grid">
                            {calcs.map(calc => (
                                <a href={`/calculator/${calc.slug}`} class="calc-list-item">
                                    <div class="calc-list-info">
                                        <span class="calc-list-name">{calc.name}</span>
                                        <span class="calc-list-desc">{calc.description}</span>
                                    </div>
                                    <span class="calc-list-arrow">→</span>
                                </a>
                            ))}
                        </div>
                    </div>
                );
            })}
        </div>

        <!-- WHY QUICKFINCALC SECTION -->
        <div class="why-section" id="whySection">
            <h2>Why Choose QuickFinCalc?</h2>
            <p>Financial decisions impact your business growth, but complex calculations drain time and introduce errors. QuickFinCalc removes the complexity. Whether you're calculating loan EMI, analyzing ROI on marketing campaigns, or determining profit margins, our professional-grade calculators deliver accurate results in seconds.</p>
            <p>No spreadsheet formulas. No accounting background required. Just instant, reliable financial insights at your fingertips — helping you understand the true cost of loans, maximize investment returns, optimize business pricing, and plan taxes effectively.</p>

            <!-- FIX 4: Honest stats — real numbers only -->
            <div class="quick-stats">
                <div class="stat-item">
                    <div class="stat-number">53</div>
                    <div class="stat-label">Free Calculators</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">6</div>
                    <div class="stat-label">Categories</div>
                </div>
