---
import calculators from '../calculators.json';
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>FinanceHub - All Calculators</title>
    <style>
        body { font-family: 'Inter', sans-serif; background: #f8fafc; margin: 0; padding: 20px; }
        .nav { background: #1e40af; color: white; padding: 15px; text-align: center; font-weight: bold; border-radius: 8px; margin-bottom: 30px; }
        .container { max-width: 900px; margin: 0 auto; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
        .calc-card { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; text-decoration: none; color: inherit; transition: 0.3s; }
        .calc-card:hover { transform: translateY(-5px); border-color: #2563eb; }
        h2 { margin: 0 0 10px 0; color: #1e3a8a; font-size: 1.2rem; }
        p { font-size: 0.9rem; color: #64748b; margin: 0; }
    </style>
</head>
<body>
    <div class="container">
        <div class="nav">FinanceHub.bd</div>
        <h1>Our Financial Calculators</h1>
        <div class="grid">
            {calculators.map((calc) => (
                <a href={`/${calc.slug}`} class="calc-card">
                    <h2>{calc.name}</h2>
                    <p>{calc.description}</p>
                    <div style="margin-top:15px; color:#2563eb; font-weight:bold; font-size:0.8rem;">Open Calculator →</div>
                </a>
            ))}
        </div>
    </div>
</body>
</html>