---
import Layout from '../layouts/Layout.astro';

const title = "Privacy Policy | FinanceHub Pro";
const description = "FinanceHub Privacy Policy — learn how we handle your data, cookies, and third-party advertising including Google AdSense.";

// JSON-LD Schema for SEO
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Privacy Policy — FinanceHub",
  "description": description,
  "url": "https://financecalculator-all.netlify.app/privacy/",
  "publisher": {
    "@type": "Person",
    "name": "Md. Merajul Islam"
  }
};
---

<Layout title={title} description={description}>
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />

    <style>
        :root {
            --primary: #1e3a8a;
            --secondary: #2563eb;
            --accent: #f0f9ff;
            --text-dark: #1e293b;
            --border: #e2e8f0;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%);
            padding: 60px 20px;
            text-align: center;
            color: white;
        }

        .hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 10px; }

        .container { max-width: 860px; margin: 40px auto; padding: 0 20px; }

        /* Meta & TOC */
        .meta-bar { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 30px; }
        .badge { padding: 6px 14px; border-radius: 999px; font-size: 0.8rem; font-weight: 600; border: 1px solid #bfdbfe; background: var(--accent); color: var(--primary); }
        .badge-green { background: #f0fdf4; color: #166534; border-color: #bbf7d0; }

        .toc { background: var(--accent); border: 1px solid #bfdbfe; border-radius: 16px; padding: 25px; margin-bottom: 30px; }
        .toc h2 { font-size: 1rem; text-transform: uppercase; margin-bottom: 15px; color: var(--primary); }
        .toc ol { padding-left: 20px; }
        .toc a { color: var(--secondary); text-decoration: none; font-size: 0.95rem; }

        /* Content Sections */
        .section { background: white; border-radius: 16px; padding: 35px; border: 1px solid var(--border); margin-bottom: 24px; box-shadow: 0 4px 6px rgba(0,0,0,0.02); }
        .section h2 { color: var(--primary); font-size: 1.4rem; border-bottom: 2px solid var(--accent); padding-bottom: 10px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .section-num { background: var(--primary); color: white; width: 28px; height: 28px; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 0.85rem; }
        
        .highlight-box { border-radius: 12px; padding: 20px; margin: 20px 0; border-left: 5px solid; }
        .highlight-green { background: #f0fdf4; border-left-color: #16a34a; color: #14532d; }
        .highlight-blue { background: var(--accent); border-left-color: var(--secondary); color: #1e3a8a; }
        .highlight-amber { background: #fffbeb; border-left-color: #d97706; color: #78350f; }

        .contact-card { background: var(--accent); border-radius: 12px; padding: 25px; border: 1px solid #bfdbfe; }
        .contact-card a { color: var(--secondary); font-weight: 700; text-decoration: none; }

        @media (max-width: 640px) {
            .section { padding: 20px; }
            .hero h1 { font-size: 2rem; }
        }
    </style>

    <section class="hero">
        <h1>Privacy Policy</h1>
        <p>Your data security and privacy are our top priorities</p>
    </section>

    <div class="container">
        <div class="meta-bar">
            <span class="badge">📅 Updated: April 1, 2026</span>
            <span class="badge badge-green">✅ AdSense Compliant</span>
            <span class="badge badge-green">✅ GDPR Aware</span>
        </div>

        <div class="toc">
            <h2>Table of Contents</h2>
            <ol>
                <li><a href="#overview">Overview</a></li>
                <li><a href="#calculator-data">Calculator Data Privacy</a></li>
                <li><a href="#google-adsense">Google AdSense & Cookies</a></li>
                <li><a href="#contact">Contact Us</a></li>
            </ol>
        </div>

        <section class="section" id="overview">
            <h2><span class="section-num">1</span> Overview</h2>
            <p>Welcome to <strong>FinanceHub Pro</strong>. This Privacy Policy outlines how we manage information when you use our financial tools. We believe in transparency and keeping your data safe.</p>
            <div class="highlight-green">
                <strong>No-Data Policy:</strong> FinanceHub does not store or see the numbers you enter. All calculations happen locally on your device.
            </div>
        </section>

        <section class="section" id="calculator-data">
            <h2><span class="section-num">2</span> Calculator Data & Your Privacy</h2>
            <p>Every financial input—whether it's your salary, loan amount, or tax details—is processed entirely within your browser using JavaScript.</p>
            <div class="highlight-blue">
                🔒 <strong>Zero Transmission:</strong> Your numbers are never sent to any server. Once you close the tab, all data is permanently cleared.
            </div>
        </section>

        <section class="section" id="google-adsense">
            <h2><span class="section-num">3</span> Google AdSense & Advertising</h2>
            <p>We use Google AdSense to show relevant ads. Google uses cookies (like the DoubleClick cookie) to serve ads based on your visit to this site and others.</p>
            <div class="highlight-amber">
                <strong>Control Your Privacy:</strong> You can opt-out of personalized ads via <a href="https://www.google.com/settings/ads" target="_blank">Google Ads Settings</a>.
            </div>
        </section>

        <section class="section" id="contact">
            <h2><span class="section-num">4</span> Contact Us</h2>
            <div class="contact-card">
                <p><strong>FinanceHub — Privacy Enquiries</strong></p>
                <p>👤 Maintained by: <strong>Md. Merajul Islam</strong></p>
                <p>📬 Contact: <a href="/contact/">Send a Message</a></p>
                <p style="font-size: 0.85rem; color: #64748b; margin-top: 10px;">We aim to respond to all privacy concerns within 5 business days.</p>
            </div>
        </section>
    </div>
</Layout>