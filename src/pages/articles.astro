---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

let allArticles = [];
try {
  // Astro v6 এ কালেকশন ফেচ করা এবং ডেট অনুযায়ী সাজানো (Latest First)
  allArticles = await getCollection('articles');
  allArticles.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
} catch (e) {
  console.error("Error fetching articles:", e);
}

const title = "Financial Knowledge Hub | Expert Insights by Md Merajul Islam";
const description = "Access professional guides on ROI, Mortgage, E-commerce margins, and Retirement planning curated by a Cost Control Specialist.";
---

<Layout title={title} description={description}>
    <style>
        .hero {
            background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
            padding: 100px 20px;
            text-align: center;
            color: white;
        }
        .container {
            max-width: 1200px;
            margin: -60px auto 80px;
            padding: 0 20px;
        }
        .article-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
        }
        .article-card {
            background: white;
            border-radius: 20px;
            padding: 30px;
            text-decoration: none;
            border: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .article-card:hover {
            transform: translateY(-10px);
            border-color: #d4a373;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }
        .emoji { font-size: 2.5rem; margin-bottom: 15px; }
        .category {
            background: #f1f5f9;
            color: #475569;
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            width: fit-content;
        }
        h2 { 
            color: #1e293b; 
            font-size: 1.4rem; 
            margin: 15px 0; 
            line-height: 1.3;
            font-family: 'Crimson Pro', serif; 
        }
        .desc { color: #64748b; font-size: 0.95rem; line-height: 1.6; margin-bottom: 20px; }
        .author-tag {
            font-size: 0.75rem;
            color: #1e3a8a;
            font-weight: 600;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .footer-meta {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            color: #94a3b8;
            font-size: 0.8rem;
            padding-top: 15px;
            border-top: 1px solid #f1f5f9;
        }
    </style>

    <section class="hero">
        <h1>Financial Knowledge Hub</h1>
        <p>Expert insights and strategic guides for your financial growth.</p>
    </section>

    <main class="container">
        {allArticles.length > 0 ? (
            <div class="article-grid">
                {allArticles.map(post => (
                    <a href={`/articles/${post.id}`} class="article-card">
                        <div class="emoji">{post.data.emoji}</div>
                        <span class="category">{post.data.category}</span>
                        <h2>{post.data.title}</h2>
                        
                        {/* Author Info - নতুন স্ট্রাকচার অনুযায়ী */}
                        {post.data.author && (
                            <div class="author-tag">
                                🛡️ {post.data.author}
                            </div>
                        )}
                        
                        <p class="desc">{post.data.description}</p>
                        
                        <div class="footer-meta">
                            <span>📅 {post.data.date}</span>
                            <span>⏱️ {post.data.readTime}</span>
                        </div>
                    </a>
                ))}
            </div>
        ) : (
            <div style="text-align: center; background: white; padding: 100px; border-radius: 24px; border: 2px dashed #e2e8f0;">
                <h3 style="color: #1e293b;">No articles found!</h3>
                <p style="color: #64748b;">Please check if your files are in <b>src/content/articles/</b> folder.</p>
            </div>
        )}
    </main>
</Layout>