---
import Layout from '../layouts/Layout.astro';
import articles from '../../articles.json'; // আপনার JSON ফাইলের লোকেশন অনুযায়ী

const title = "Financial Insights & Expert Guides | Quick Financial Calculator";
const description = "Master your finances with expert guides on loan strategies, tax planning, and business analysis.";
---

<Layout title={title} description={description}>
    <style>
        .hero {
            background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
            color: white; padding: 80px 20px; text-align: center; border-bottom: 4px solid #d4a373;
        }
        .hero h1 { font-size: 3rem; font-family: 'Crimson Pro', serif; margin-bottom: 1rem; }
        
        .articles-grid { 
            max-width: 1200px; margin: 60px auto; padding: 0 20px;
            display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px; 
        }
        .article-card { 
            background: white; border-radius: 15px; overflow: hidden; border: 1px solid #e2e8f0;
            text-decoration: none; display: flex; flex-direction: column; transition: 0.3s;
        }
        .article-card:hover { transform: translateY(-10px); box-shadow: 0 15px 30px rgba(0,0,0,0.1); border-color: #d4a373; }
        
        .card-img { height: 180px; background: #f8fafc; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; position: relative; }
        .cat-tag { position: absolute; top: 15px; left: 15px; background: #1e3a8a; color: #d4a373; padding: 4px 12px; border-radius: 5px; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; }
        
        .card-body { padding: 25px; }
        .card-body h2 { font-family: 'Crimson Pro', serif; color: #1e3a8a; font-size: 1.4rem; margin-bottom: 12px; }
        .card-body p { color: #64748b; font-size: 0.95rem; line-height: 1.6; }
    </style>

    <section class="hero">
        <h1>Financial Knowledge Hub</h1>
        <p>Expert insights and strategic guides for your financial growth.</p>
    </section>

    <main class="articles-grid">
        {articles.map((post) => (
            <a href={`/articles/${post.slug}`} class="article-card">
                <div class="card-img">
                    {post.emoji}
                    <span class="cat-tag">{post.category}</span>
                </div>
                <div class="card-body">
                    <h2>{post.title}</h2>
                    <p>{post.excerpt}</p>
                </div>
            </a>
        ))}
    </main>
</Layout>