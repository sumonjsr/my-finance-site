---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

let allArticles = [];
try {
  // Astro v6 - Collection fetch & sort by date (Latest First)
  allArticles = await getCollection('articles');
  allArticles.sort((a, b) => 
    new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
} catch (e) {
  console.error("Error fetching articles:", e);
}

// ✅ SEO - Optimized Title & Description
const title = "Financial Guides & Expert Articles | Knowledge Hub";
const description = "Explore expert financial guides on ROI, mortgage, e-commerce margins & retirement planning. Written by professionals to help you make smarter money decisions.";

// ✅ Date Formatter - Clean date display
const formatDate = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};
---

<Layout title={title} description={description}>

  <!-- ✅ SEO: Open Graph & Schema Tags -->
  <Fragment slot="head">
    <!-- Open Graph -->
    <meta property="og:title" content={`${title} | QuickFinCalc`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://quickfincalc.com/articles" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | QuickFinCalc`} />
    <meta name="twitter:description" content={description} />

    <!-- ✅ Canonical Tag -->
    <link rel="canonical" href="https://quickfincalc.com/articles" />

    <!-- ✅ Blog Schema Markup -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Blog",
        "name": "QuickFinCalc Financial Knowledge Hub",
        "description": description,
        "url": "https://quickfincalc.com/articles",
        "publisher": {
          "@type": "Organization",
          "name": "QuickFinCalc",
          "url": "https://quickfincalc.com"
        }
      })}
    </script>
  </Fragment>

  <style>
    /* ✅ Hero Section */
    .hero {
      background: linear-gradient(135deg, #1e3a8a 0%, #0f172a 100%);
      padding: 100px 20px;
      text-align: center;
      color: white;
    }

    /* ✅ Updated H1 - SEO Optimized */
    .hero h1 {
      font-size: 2.8rem;
      font-weight: 700;
      margin-bottom: 15px;
      font-family: 'Crimson Pro', serif;
    }

    .hero p {
      font-size: 1.1rem;
      color: #94a3b8;
      max-width: 600px;
      margin: 0 auto 20px;
    }

    /* ✅ Article Count Badge - নতুন */
    .article-count {
      display: inline-block;
      background: rgba(255,255,255,0.1);
      color: #e2e8f0;
      padding: 6px 18px;
      border-radius: 50px;
      font-size: 0.85rem;
      font-weight: 600;
      margin-top: 10px;
      border: 1px solid rgba(255,255,255,0.2);
    }

    /* ✅ Container */
    .container {
      max-width: 1200px;
      margin: -60px auto 80px;
      padding: 0 20px;
    }

    /* ✅ Article Grid */
    .article-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 25px;
    }

    /* ✅ Article Card */
    .article-card {
      background: white;
      border-radius: 20px;
      padding: 30px;
      text-decoration: none;
      border: 1px solid #e2e8f0;
      display: flex;
      flex-direction: column;
      transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .article-card:hover {
      transform: translateY(-10px);
      border-color: #d4a373;
      box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    }

    .emoji { 
      font-size: 2.5rem; 
      margin-bottom: 15px; 
    }

    .category {
      background: #f1f5f9;
      color: #475569;
      padding: 4px 12px;
      border-radius: 50px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      width: fit-content;
    }

    h2 {
      color: #1e293b;
      font-size: 1.4rem;
      margin: 15px 0;
      line-height: 1.3;
      font-family: 'Crimson Pro', serif;
    }

    .desc { 
      color: #64748b; 
      font-size: 0.95rem; 
      line-height: 1.6; 
      margin-bottom: 20px; 
    }

    .author-tag {
      font-size: 0.75rem;
      color: #1e3a8a;
      font-weight: 600;
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    /* ✅ Footer Meta - Updated with better date */
    .footer-meta {
      margin-top: auto;
      display: flex;
      justify-content: space-between;
      color: #94a3b8;
      font-size: 0.8rem;
      padding-top: 15px;
      border-top: 1px solid #f1f5f9;
    }

    /* ✅ Empty State - Updated */
    .empty-state {
      text-align: center;
      background: white;
      padding: 100px;
      border-radius: 24px;
      border: 2px dashed #e2e8f0;
    }

    .empty-state h3 { color: #1e293b; }
    .empty-state p { color: #64748b; }
  </style>

  <!-- ✅ Hero Section - SEO Optimized H1 -->
  <section class="hero">
    <h1>Financial Knowledge Hub</h1>
    <p>Expert guides & insights on ROI, mortgage, tax planning & investment strategies.</p>
    <!-- ✅ Article Count - Dynamic -->
    {allArticles.length > 0 && (
      <span class="article-count">
        📚 {allArticles.length} Expert Articles Available
      </span>
    )}
  </section>

  <main class="container">
    {allArticles.length > 0 ? (
      <div class="article-grid">
        {allArticles.map(post => (
          <a href={`/articles/${post.id}`} class="article-card">
            
            <div class="emoji">{post.data.emoji}</div>
            <span class="category">{post.data.category}</span>
            <h2>{post.data.title}</h2>

            {/* ✅ Author Info */}
            {post.data.author && (
              <div class="author-tag">
                🛡️ {post.data.author}
              </div>
            )}

            <p class="desc">{post.data.description}</p>

            {/* ✅ Footer Meta - Formatted Date */}
            <div class="footer-meta">
              <span>📅 {formatDate(post.data.date)}</span>
              <span>⏱️ {post.data.readTime}</span>
            </div>

          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h3>No articles found!</h3>
        <p>Please check if your files are in <b>src/content/articles/</b> folder.</p>
      </div>
    )}
  </main>

</Layout>