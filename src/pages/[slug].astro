---
import Layout from '../layouts/Layout.astro';
import calculators from '../data/calculators.json';

export async function getStaticPaths() {
  return calculators.map((calc) => ({
    params: { slug: calc.slug },
    props: { calc },
  }));
}

const { calc } = Astro.props;

// Related Tools Logic
const suggestions = calculators
  .filter(item => item.slug !== calc.slug && item.type === calc.type)
  .sort(() => 0.5 - Math.random())
  .slice(0, 3);

const title = `${calc.name} | FinanceHub Pro`;
---

<Layout title={title} description={calc.description}>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": calc.name,
      "description": calc.description,
      "applicationCategory": "FinanceApplication",
      "operatingSystem": "Web",
      "author": {
          "@type": "Person",
          "name": "Md. Merajul Islam"
      }
    })} />

    <style>
        .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
        .calc-box { 
            background: white; padding: 45px; border-radius: 24px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); border: 1px solid #e2e8f0; 
            margin-bottom: 40px; 
        }
        h1 { color: #1e3a8a; font-size: 2.5rem; text-align: center; margin-bottom: 10px; }
        .desc-top { text-align: center; color: #64748b; margin-bottom: 35px; font-size: 1.1rem; }
        
        .input-group { max-width: 450px; margin: 0 auto; }
        label { display: block; font-weight: 600; margin-bottom: 8px; color: #1e293b; }
        input { 
            width: 100%; padding: 15px; margin-bottom: 25px; 
            border: 1.5px solid #cbd5e1; border-radius: 12px; font-size: 1rem; 
            transition: 0.3s;
        }
        input:focus { border-color: #2563eb; outline: none; box-shadow: 0 0 0 4px #f0f9ff; }
        
        button { 
            width: 100%; padding: 18px; background: #1e3a8a; color: white; 
            border: none; border-radius: 14px; cursor: pointer; font-weight: 700; 
            font-size: 1.1rem; transition: 0.3s; 
        }
        button:hover { background: #2563eb; transform: translateY(-2px); }

        .result-box { 
            margin-top: 30px; padding: 25px; background: #dcfce7; 
            border-radius: 18px; border: 1px solid #bbf7d0; display: none; 
            color: #166534; text-align: center; font-size: 1.2rem; font-weight: 800; 
        }

        .rich-content { background: white; padding: 40px; border-radius: 24px; border: 1px solid #e2e8f0; }
        .rich-content h2 { color: #1e3a8a; margin-top: 30px; border-bottom: 2px solid #f0f9ff; padding-bottom: 8px; }
        .pro-tip { background: #eff6ff; border-left: 5px solid #2563eb; padding: 20px; border-radius: 8px; margin: 30px 0; }
        
        .sugg-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .sugg-card { background: white; padding: 20px; border-radius: 15px; border: 1px solid #e2e8f0; text-decoration: none; transition: 0.2s; }
        .sugg-card:hover { border-color: #2563eb; transform: translateY(-5px); }
    </style>

    <div class="container">
        <div class="calc-box">
            <h1>{calc.name}</h1>
            <p class="desc-top">{calc.description}</p>
            
            <div class="input-group">
                <label for="input1">{calc.label1}</label>
                <input type="number" id="input1" placeholder="e.g. 50000" step="any" />
                
                <label for="input2">{calc.label2}</label>
                <input type="number" id="input2" placeholder="e.g. 12" step="any" />
                
                {calc.label3 && (
                    <label for="input3">{calc.label3}</label>
                    <input type="number" id="input3" placeholder="e.g. 5" step="any" />
                )}
                
                <button id="calcBtn">Calculate Now</button>
                <div id="result" class="result-box"></div>
            </div>
        </div>

        <div class="rich-content">
            <h2>What is {calc.name}?</h2>
            <p>{calc.what_is}</p>

            <h2>Step-by-Step Guide</h2>
            <div style="white-space: pre-line; background: #f8fafc; padding: 20px; border-radius: 12px;">
                {calc.how_to_use}
            </div>

            <div class="pro-tip">
                <strong>💡 Pro Tip:</strong>
                <p>{calc.pro_tip}</p>
            </div>

            <h2>How to Interpret the Result</h2>
            <p>{calc.how_to_read}</p>
        </div>

        {suggestions.length > 0 && (
            <div style="margin-top: 50px;">
                <h3 style="color: #1e3a8a;">Related {calc.type} Tools</h3>
                <div class="sugg-grid">
                    {suggestions.map(s => (
                        <a href={`/${s.slug}/`} class="sugg-card">
                            <h4 style="margin:0; color: #1e3a8a;">{s.name}</h4>
                            <p style="font-size: 0.85rem; color: #64748b; margin: 10px 0;">{s.description}</p>
                            <span style="color: #2563eb; font-weight: 600; font-size: 0.9rem;">Try it &rarr;</span>
                        </a>
                    ))}
                </div>
            </div>
        )}
    </div>

    <script define:vars={{ type: calc.type, slug: calc.slug }}>
        const btn = document.getElementById('calcBtn');
        const resDiv = document.getElementById('result');

        btn.addEventListener('click', () => {
            const v1 = parseFloat(document.getElementById('input1').value);
            const v2 = parseFloat(document.getElementById('input2').value);
            const v3El = document.getElementById('input3');
            const v3 = v3El ? parseFloat(v3El.value) : null;

            if (isNaN(v1) || isNaN(v2)) {
                alert("Please enter valid numbers.");
                return;
            }

            let out = "";
            const fmt = (num) => num.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});

            // Logic sections (Loan, Investment, Ecommerce etc. stay as per your code)
            // Example update for formatting:
            if (type === 'loan') {
                if (slug === 'debt-to-income-ratio') {
                    out = `DTI Ratio: ${((v1 / v2) * 100).toFixed(2)}%`;
                } else {
                    const r = (v2 / 12) / 100;
                    const emi = (v1 * r * Math.pow(1 + r, v3)) / (Math.pow(1 + r, v3) - 1);
                    out = `Monthly Payment: $${fmt(emi)}`;
                }
            }
            // ... rest of your logic ...

            resDiv.innerText = out;
            resDiv.style.display = 'block';
            resDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
    </script>
</Layout>