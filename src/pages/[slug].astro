---
import Layout from '../layouts/Layout.astro';
import calculators from '../../calculators.json';

export async function getStaticPaths() {
  return calculators.map((calc) => ({
    params: { slug: calc.slug },
    props: { calc },
  }));
}

const { calc } = Astro.props;

// যদি কোনো কারণে calc না পাওয়া যায় (যেমন favicon.ico এর ক্ষেত্রে)
if (!calc) {
  return Astro.redirect('/404');
}

const title = `${calc.name}`;
---

<Layout title={title} description={calc.description}>
  <div class="container">
    <div class="calc-box">
      <h1>{calc.name}</h1>
      <p class="desc-top">{calc.description}</p>

      <div class="input-group">
        <label for="v1">{calc.label1}</label>
        <input type="number" id="v1" class="calc-input" placeholder="0.00" step="any" />

        {calc.label2 && (
          <label for="v2">{calc.label2}</label>
          <input type="number" id="v2" class="calc-input" placeholder="0.00" step="any" />
        )}

        {calc.label3 && (
          <label for="v3">{calc.label3}</label>
          <input type="number" id="v3" class="calc-input" placeholder="0.00" step="any" />
        )}

        <button id="calcBtn">Calculate Now</button>
        <div id="result" class="result-box"></div>
      </div>
    </div>

    <div class="rich-content">
      <h2>What is {calc.name}?</h2>
      <p>{calc.what_is}</p>
      
      <h2>How to Use</h2>
      <p style="white-space: pre-line;">{calc.how_to_use}</p>

      <div class="pro-tip">
        <strong>💡 Pro Tip:</strong> {calc.pro_tip}
      </div>
    </div>
  </div>

  <style>
    .container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
    .calc-box { 
      background: #ffffff; padding: 40px; border-radius: 20px; 
      box-shadow: 0 4px 25px rgba(0,0,0,0.06); border: 1px solid #f1f5f9;
      margin-bottom: 30px;
    }
    h1 { color: #1e3a8a; text-align: center; font-size: 2.2rem; font-family: 'Crimson Pro', serif; margin-bottom: 10px; }
    .desc-top { text-align: center; color: #64748b; margin-bottom: 30px; font-size: 1.1rem; }
    .input-group { max-width: 450px; margin: 0 auto; }
    label { display: block; font-weight: 600; margin-bottom: 8px; color: #334155; font-size: 0.95rem; }
    .calc-input { 
      width: 100%; padding: 14px; margin-bottom: 22px; 
      border: 2px solid #e2e8f0; border-radius: 10px; transition: 0.3s;
      font-size: 1rem;
    }
    .calc-input:focus { border-color: #d4a373; outline: none; background: #fffcf9; }
    button { 
      width: 100%; padding: 16px; background: #1e3a8a; color: white; 
      border: none; border-radius: 10px; font-weight: 700; cursor: pointer;
      font-size: 1.1rem; transition: 0.3s;
    }
    button:hover { background: #0f172a; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
    .result-box { 
      margin-top: 25px; padding: 25px; border-radius: 12px; 
      background: #f8fafc; color: #1e3a8a; font-weight: 800; 
      display: none; text-align: center; border: 2px solid #d4a373;
      font-size: 1.25rem; line-height: 1.6;
    }
    .rich-content { background: white; padding: 40px; border-radius: 20px; border: 1px solid #e2e8f0; line-height: 1.8; color: #475569; }
    .rich-content h2 { color: #1e3a8a; font-family: 'Crimson Pro', serif; margin: 25px 0 15px; font-size: 1.8rem; }
    .pro-tip { background: #fffbeb; padding: 25px; border-radius: 12px; margin-top: 30px; border-left: 5px solid #d4a373; color: #92400e; }
  </style>

<script define:vars={{ formula: calc.formula }}>
  const btn = document.getElementById('calcBtn');
  const resDiv = document.getElementById('result');

  // ফিনান্সিয়াল ফরম্যাটার
  const fmt = (num) => new Intl.NumberFormat('en-US', {
    style: 'currency', currency: 'USD'
  }).format(num);
  
  const pct = (num) => isFinite(num) ? num.toFixed(2) + '%' : '0.00%';

  btn.addEventListener('click', () => {
    const v1 = parseFloat(document.getElementById('v1')?.value || 0);
    const v2 = parseFloat(document.getElementById('v2')?.value || 0);
    const v3 = parseFloat(document.getElementById('v3')?.value || 0);

    let out = "";

    switch (formula) {
      case 'dividend':
        // v1: Dividend/Share, v2: Price, v3: Quantity
        const dYield = (v1 / v2) * 100;
        const dIncome = v1 * v3;
        out = `Dividend Yield: ${pct(dYield)} <br/> <small>Annual Income: ${fmt(dIncome)}</small>`;
        break;

      case 'roi':
        if (v3 > 0) {
            // Rental/Property ROI: ((Income - Expense) / Value) * 100
            const propReturn = ((v1 - v2) / v3) * 100;
            out = `Annual ROI: ${pct(propReturn)} <br/> <small>Net Income: ${fmt(v1 - v2)}</small>`;
        } else {
            // Basic Investment ROI: ((Final - Initial) / Initial) * 100
            const basicReturn = ((v1 - v2) / v2) * 100;
            out = `Total ROI: ${pct(basicReturn)} <br/> <small>Net Profit: ${fmt(v1 - v2)}</small>`;
        }
        break;

      case 'loan':
        const r = (v2 / 12) / 100;
        const emi = r > 0 ? (v1 * r * Math.pow(1 + r, v3)) / (Math.pow(1 + r, v3) - 1) : v1 / v3;
        out = `Monthly Payment: ${fmt(emi)} <br/> <small>Total Repayment: ${fmt(emi * v3)}</small>`;
        break;

      case 'tax':
        const tAmt = v1 * (v2 / 100);
        out = `Tax Amount: ${fmt(tAmt)} <br/> <small>Total Due: ${fmt(v1 + tAmt)}</small>`;
        break;

      case 'margin':
        const pMargin = ((v1 - v2) / v1) * 100;
        out = `Profit Margin: ${pct(pMargin)} <br/> <small>Gross Profit: ${fmt(v1 - v2)}</small>`;
        break;

      case 'compound':
        const fv = v1 * Math.pow(1 + (v2 / 100) / 12, 12 * v3);
        out = `Future Value: ${fmt(fv)} <br/> <small>Total Interest: ${fmt(fv - v1)}</small>`;
        break;

      case 'stock':
        const sProfit = (v2 - v1) * v3;
        out = `Net Profit/Loss: ${fmt(sProfit)} <br/> <small>Growth: ${pct(((v2 - v1) / v1) * 100)}</small>`;
        break;

      case 'break_even':
        const contrib = v3 - v2;
        if (contrib <= 0) {
            out = "Price must be higher than variable cost.";
        } else {
            out = `Break-even Point: ${Math.ceil(v1 / contrib).toLocaleString()} Units`;
        }
        break;

      default:
        out = "Calculation formula mismatch. Please check configuration.";
    }

    resDiv.innerHTML = out;
    resDiv.style.display = 'block';
  });
</script>
</Layout>