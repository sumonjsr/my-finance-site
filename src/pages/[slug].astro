---
import Layout from '../layouts/Layout.astro';
import calculators from '../../calculators.json';

export async function getStaticPaths() {
  return calculators.map((calc) => ({
    params: { slug: calc.slug },
    props: { calc },
  }));
}

const { calc } = Astro.props;

const title = `${calc.name} | QuickFinCalc`;
---

<Layout title={title} description={calc.description}>
  <div class="container">
    <div class="calc-box">
      <h1>{calc.name}</h1>
      <p class="desc-top">{calc.description}</p>

      <div class="input-group">
        <label for="v1">{calc.label1}</label>
        <input type="number" id="v1" class="calc-input" placeholder="Enter value" step="any" />

        <label for="v2">{calc.label2}</label>
        <input type="number" id="v2" class="calc-input" placeholder="Enter value" step="any" />

        {calc.label3 && (
          <label for="v3">{calc.label3}</label>
          <input type="number" id="v3" class="calc-input" placeholder="Enter value" step="any" />
        )}

        <button id="calcBtn">Calculate Now</button>
        <div id="result" class="result-box"></div>
      </div>
    </div>

    <div class="rich-content">
      <h2>What is {calc.name}?</h2>
      <p>{calc.what_is}</p>
      
      <h2>How to Use</h2>
      <p style="white-space: pre-line;">{calc.how_to_use}</p>

      <div class="pro-tip">
        <strong>💡 Pro Tip:</strong> {calc.pro_tip}
      </div>
    </div>
  </div>

  <style>
    .container { max-width: 800px; margin: 0 auto; padding: 40px 20px; }
    .calc-box { 
      background: #ffffff; padding: 40px; border-radius: 20px; 
      box-shadow: 0 4px 20px rgba(0,0,0,0.05); border: 1px solid #f1f5f9;
      margin-bottom: 30px;
    }
    h1 { color: #1e3a8a; text-align: center; font-size: 2rem; }
    .desc-top { text-align: center; color: #64748b; margin-bottom: 30px; }
    .input-group { max-width: 400px; margin: 0 auto; }
    label { display: block; font-weight: 600; margin-bottom: 8px; color: #334155; }
    .calc-input { 
      width: 100%; padding: 12px; margin-bottom: 20px; 
      border: 1px solid #cbd5e1; border-radius: 8px; 
    }
    button { 
      width: 100%; padding: 15px; background: #1e3a8a; color: white; 
      border: none; border-radius: 10px; font-weight: 700; cursor: pointer;
    }
    .result-box { 
      margin-top: 20px; padding: 20px; border-radius: 10px; 
      background: #f0fdf4; color: #166534; font-weight: 800; 
      display: none; text-align: center; border: 1px solid #bbf7d0;
    }
    .rich-content { background: white; padding: 30px; border-radius: 20px; border: 1px solid #e2e8f0; }
    .pro-tip { background: #eff6ff; padding: 20px; border-radius: 10px; margin-top: 20px; border-left: 4px solid #1e3a8a; }
  </style>

<script define:vars={{ formula: calc.formula }}>
  const btn = document.getElementById('calcBtn');
  const resDiv = document.getElementById('result');

  // ফিনান্সিয়াল ফরম্যাটার
  const fmt = (num) => new Intl.NumberFormat('en-US', {
    style: 'currency', currency: 'USD', maximumFractionDigits: 0
  }).format(num);
  
  const pct = (num) => isFinite(num) ? num.toFixed(2) + '%' : '0.00%';

  btn.addEventListener('click', () => {
    const v1 = parseFloat(document.getElementById('v1').value);
    const v2 = parseFloat(document.getElementById('v2').value);
    const v3El = document.getElementById('v3');
    const v3 = v3El ? parseFloat(v3El.value) : 0;

    if (isNaN(v1) || isNaN(v2)) {
      alert("Please enter valid numbers in the required fields.");
      return;
    }

    let out = "";

    // ইউনিversal ক্যালকুলেশন ইঞ্জিন (Formula Based)
    switch (formula) {
      case 'loan':
        // Standard EMI Formula: [P x R x (1+R)^N]/[(1+R)^N-1]
        const r = (v2 / 12) / 100;
        const emi = r > 0 ? (v1 * r * Math.pow(1 + r, v3)) / (Math.pow(1 + r, v3) - 1) : v1 / v3;
        out = `Monthly Payment: ${fmt(emi)} | Total: ${fmt(emi * v3)}`;
        break;

      case 'margin':
        // ((Revenue - Cost) / Revenue) * 100
        const marginPct = ((v1 - v2) / v1) * 100;
        out = `Profit Margin: ${pct(marginPct)} | Profit: ${fmt(v1 - v2)}`;
        break;

      case 'break_even':
        // Fixed Costs / (Selling Price - Variable Cost)
        if (v3 <= v2) {
          out = "Price must be higher than Variable Cost";
        } else {
          out = `Break-even Point: ${Math.ceil(v1 / (v3 - v2)).toLocaleString()} Units`;
        }
        break;

      case 'runway':
        // Cash / (Monthly Expenses - Monthly Revenue)
        const netBurn = v2 - v3;
        out = netBurn <= 0 ? "Infinite Runway (Profitable)" : `Runway: ${(v1 / netBurn).toFixed(1)} Months`;
        break;

      case 'ratio':
        // Current Assets / Current Liabilities
        out = `Ratio Result: ${(v1 / v2).toFixed(2)}`;
        break;

      case 'tax':
        // Amount * Tax Rate
        const taxAmount = v1 * (v2 / 100);
        out = `Tax: ${fmt(taxAmount)} | Total: ${fmt(v1 + taxAmount)}`;
        break;

      case 'roi':
        // v1 = Final Value, v2 = Initial Cost
        out = `Total ROI: ${pct(((v1 - v2) / v2) * 100)} | Net Gain: ${fmt(v1 - v2)}`;
        break;

      case 'compound':
        // FV = P * (1 + r/n)^(nt)
        const futureValue = v1 * Math.pow(1 + (v2 / 100) / 12, 12 * v3);
        out = `Future Value: ${fmt(futureValue)} | Interest: ${fmt(futureValue - v1)}`;
        break;

      case 'property_roi':
        // ((Annual Income - Expenses) / Property Value) * 100
        out = `Annual ROI: ${pct(((v1 - v2) / v3) * 100)}`;
        break;

      case 'stock':
        // (Sell Price - Buy Price) * Quantity
        const totalProfit = (v2 - v1) * v3;
        out = `Profit/Loss: ${fmt(totalProfit)} (${pct(((v2 - v1) / v1) * 100)})`;
        break;

      case 'fee':
        // (Amount * %) + Fixed Fee
        const fee = (v1 * (v2 / 100)) + v3;
        out = `Fee: ${fmt(fee)} | Net Amount: ${fmt(v1 - fee)}`;
        break;

      case 'basic':
      default:
        // Basic calculations like Hourly to Salary
        if (v3 > 0) {
           out = `Total Result: ${(v1 + v2 + v3).toLocaleString()}`;
        } else {
           out = `Result: ${(v1 + v2).toLocaleString()}`;
        }
    }

    resDiv.innerText = out;
    resDiv.style.display = 'block';
  });
</script>
</Layout>