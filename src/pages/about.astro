---
import Layout from '../layouts/Layout.astro';

const title = "About Quick Financial Calculator | Professional Grade Tools";
const description = "Quick Financial Calculator offers 50+ free, browser-based tools for tax, loans, business analysis, and investment planning. Engineered for precision and privacy.";
---

<Layout title={title} description={description}>
    <link rel="canonical" href="https://quickfincalc.com/about/" slot="head" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "AboutPage",
      "name": "About Quick Financial Calculator",
      "description": description,
      "url": "https://quickfincalc.com/about/",
      "publisher": {
        "@type": "Person",
        "name": "Md. Merajul Islam",
        "email": "merajul.audit@gmail.com",
        "jobTitle": "Internal Audit Professional"
      }
    })} slot="head" />

    <style>
        :root {
            --primary: #1e3a8a;
            --secondary: #0f172a;
            --accent-gold: #d4a373;
            --bg-light: #fdfbf7;
            --text-slate: #475569;
            --border-soft: #e2e8f0;
        }

        /* Hero */
        .hero {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            padding: 80px 20px;
            text-align: center;
            color: white;
            border-bottom: 4px solid var(--accent-gold);
        }
        .hero h1 {
            font-family: 'Crimson Pro', serif;
            font-size: 3rem;
            font-weight: 800;
            margin: 0 0 16px;
            line-height: 1.1;
        }
        .hero p { font-size: 1.15rem; max-width: 650px; margin: 0 auto; color: #cbd5e1; }

        /* Stats Bar */
        .stats-bar { background: white; border-bottom: 1px solid var(--border-soft); padding: 28px 20px; }
        .stats-grid { max-width: 900px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; text-align: center; }
        .stat-num { font-size: 2.2rem; font-weight: 800; color: var(--primary); font-family: 'Crimson Pro', serif; }
        .stat-label { font-size: 0.85rem; color: #64748b; margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }

        .container { max-width: 860px; margin: 50px auto; padding: 0 20px; }

        /* Sections */
        .section { background: white; border-radius: 16px; padding: 44px; border: 1px solid var(--border-soft); margin-bottom: 30px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
        .section h2 {
            color: var(--primary);
            font-family: 'Crimson Pro', serif;
            font-size: 1.8rem;
            margin: 0 0 20px;
            padding-bottom: 12px;
            border-bottom: 3px solid var(--bg-light);
        }
        .section p { color: var(--text-slate); line-height: 1.75; margin-bottom: 15px; }

        /* Feature Grid */
        .feature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 24px; }
        .feature-card { background: var(--bg-light); border-radius: 12px; padding: 22px; border: 1px solid var(--border-soft); border-left: 4px solid var(--accent-gold); }
        .feature-icon { font-size: 1.6rem; margin-bottom: 10px; }
        .feature-title { font-weight: 700; color: var(--primary); font-size: 1rem; margin-bottom: 6px; }
        .feature-desc { font-size: 0.875rem; color: var(--text-slate); line-height: 1.6; }

        /* ✅ IMPROVED: Author Card */
        .author-card {
            display: flex;
            align-items: flex-start;
            gap: 24px;
            background: #f8fafc;
            border-radius: 16px;
            padding: 32px;
            border: 1px solid var(--border-soft);
            margin-top: 25px;
        }
        .author-avatar {
            width: 72px;
            height: 72px;
            border-radius: 14px;
            background: var(--primary);
            color: var(--accent-gold);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            font-weight: 800;
            flex-shrink: 0;
            box-shadow: 0 4px 14px rgba(30,58,138,0.25);
            letter-spacing: -1px;
        }
        .author-name { font-weight: 800; color: var(--primary); font-size: 1.15rem; margin-bottom: 4px; }
        .author-title { font-size: 0.82rem; color: var(--accent-gold); font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 12px; }
        .author-bio { font-size: 0.95rem; color: var(--text-slate); line-height: 1.65; margin-bottom: 16px; }

        /* ✅ NEW: Author Contact / Identity Links */
        .author-links { display: flex; flex-wrap: wrap; gap: 10px; }
        .author-link {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 0.82rem;
            font-weight: 700;
            text-decoration: none;
            border: 1px solid;
            transition: all 0.2s ease;
        }
        .link-email {
            background: #f0f7ff;
            color: var(--primary);
            border-color: #bfdbfe;
        }
        .link-email:hover { background: var(--primary); color: white; border-color: var(--primary); }
        .link-site {
            background: var(--bg-light);
            color: #92400e;
            border-color: var(--accent-gold);
        }
        .link-site:hover { background: var(--accent-gold); color: var(--primary); }

        /* ✅ NEW: Trust / AdSense Credibility Badge Strip */
        .trust-strip {
            background: var(--bg-light);
            border: 1px solid var(--border-soft);
            border-radius: 12px;
            padding: 20px 28px;
            margin-top: 28px;
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            align-items: center;
            justify-content: center;
        }
        .trust-badge {
            font-size: 0.78rem;
            font-weight: 700;
            color: #64748b;
            background: white;
            border: 1px solid var(--border-soft);
            border-radius: 6px;
            padding: 6px 13px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        /* ✅ NEW: Mission Commitment List */
        .commitment-list { list-style: none; padding: 0; margin: 20px 0 0; }
        .commitment-list li {
            padding: 12px 0;
            border-bottom: 1px solid var(--border-soft);
            color: var(--text-slate);
            font-size: 0.95rem;
            line-height: 1.6;
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }
        .commitment-list li:last-child { border-bottom: none; }
        .commitment-list .check { color: #16a34a; font-size: 1rem; margin-top: 2px; flex-shrink: 0; }

        /* CTA Box */
        .cta-box {
            background: var(--primary);
            border-radius: 20px;
            padding: 50px;
            text-align: center;
            color: white;
            margin-bottom: 30px;
            border: 2px solid var(--accent-gold);
        }
        .cta-box h2 { font-family: 'Crimson Pro', serif; font-size: 2.2rem; margin-bottom: 15px; color: white; border: none; padding: 0; }
        .cta-box p { color: #cbd5e1; margin-bottom: 30px; font-size: 1rem; }
        .cta-btn {
            display: inline-block;
            background: var(--accent-gold);
            color: var(--primary);
            font-weight: 700;
            padding: 16px 36px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 1.05rem;
            transition: all 0.3s ease;
        }
        .cta-btn:hover { background: white; transform: translateY(-3px); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }

        @media (max-width: 600px) {
            .author-card { flex-direction: column; text-align: center; }
            .author-links { justify-content: center; }
            .section { padding: 28px; }
            .hero h1 { font-size: 2.2rem; }
            .cta-box { padding: 35px 24px; }
        }
    </style>

    <!-- Hero -->
    <section class="hero">
        <h1>Precision Engineered<br/>Financial Clarity</h1>
        <p>Expert-grade tools for tax planning, loan management, and business analysis — simplified for everyone, completely free.</p>
    </section>

    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stats-grid">
            <div>
                <div class="stat-num">50+</div>
                <div class="stat-label">Free Calculators</div>
            </div>
            <div>
                <div class="stat-num">100%</div>
                <div class="stat-label">Privacy Guaranteed</div>
            </div>
            <div>
                <div class="stat-num">$0</div>
                <div class="stat-label">Subscription Fees</div>
            </div>
            <div>
                <div class="stat-num">Audit</div>
                <div class="stat-label">Grade Accuracy</div>
            </div>
        </div>
    </div>

    <div class="container">

        <!-- Mission -->
        <article class="section">
            <h2>The QuickFinCalc Mission</h2>
            <p><strong>Quick Financial Calculator</strong> (QuickFinCalc) was built on a simple premise: professional-grade financial tools should be freely accessible to everyone — from first-time home buyers to seasoned business analysts.</p>
            <p>We remove the complexity of spreadsheets and the guesswork of unverified online tools by offering calculators that are cross-referenced against internationally recognized accounting and banking standards.</p>
            <ul class="commitment-list">
                <li><span class="check">✔</span><span>Every calculator runs entirely in your browser — your data never touches our servers.</span></li>
                <li><span class="check">✔</span><span>Formulas are validated against GAAP, IFRS, and standard actuarial principles.</span></li>
                <li><span class="check">✔</span><span>No registration, no subscription, no hidden fees — ever.</span></li>
                <li><span class="check">✔</span><span>Tools are regularly reviewed and updated as tax laws and financial regulations change.</span></li>
            </ul>
        </article>

        <!-- Why Trust -->
        <article class="section">
            <h2>Why Professionals Trust Our Tools</h2>
            <div class="feature-grid">
                <div class="feature-card">
                    <div class="feature-icon">🛡️</div>
                    <div class="feature-title">Data Sovereignty</div>
                    <div class="feature-desc">Your financial inputs stay on your device. Zero data is transmitted, stored, or logged anywhere.</div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔍</div>
                    <div class="feature-title">Auditor Verified</div>
                    <div class="feature-desc">Formulas are cross-referenced against international accounting, banking, and tax standards.</div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🚀</div>
                    <div class="feature-title">Zero Friction</div>
                    <div class="feature-desc">No accounts, no paywalls. Just instant, accurate financial computation at your fingertips.</div>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📊</div>
                    <div class="feature-title">Business Focused</div>
                    <div class="feature-desc">Optimized for entrepreneurs, SME owners, students, and financial analysts worldwide.</div>
                </div>
            </div>
        </article>

        <!-- ✅ IMPROVED: Developer / Author Section -->
        <article class="section">
            <h2>About the Developer</h2>
            <p>QuickFinCalc is independently designed, built, and maintained by a practicing internal audit professional. Every tool on this platform reflects real-world financial rigor — not just theoretical formulas.</p>

            <div class="author-card">
                <div class="author-avatar">MI</div>
                <div style="flex: 1;">
                    <div class="author-name">Md. Merajul Islam</div>
                    <div class="author-title">Internal Audit Professional</div>
                    <p class="author-bio">
                        With hands-on experience in internal auditing and financial compliance, Merajul built QuickFinCalc to bridge the gap between enterprise-grade financial tools and everyday users. Each calculator is engineered with the same standards applied in professional audit engagements — ensuring reliability, accuracy, and transparency.
                    </p>
                    {/* ✅ Email + Contact links instead of LinkedIn */}
                    <div class="author-links">
                        <a href="mailto:merajul.audit@gmail.com" class="author-link link-email">
                            ✉️ merajul.audit@gmail.com
                        </a>
                        <a href="/contact/" class="author-link link-site">
                            💬 Send a Message
                        </a>
                    </div>
                </div>
            </div>

            {/* ✅ NEW: Trust/Credibility Badge Strip for AdSense */}
            <div class="trust-strip">
                <span class="trust-badge">✔ Audit Professional</span>
                <span class="trust-badge">✔ IFRS Aligned</span>
                <span class="trust-badge">✔ GAAP Standards</span>
                <span class="trust-badge">✔ 50+ Tools Built</span>
                <span class="trust-badge">✔ Privacy First</span>
                <span class="trust-badge">✔ Ad-Supported & Free</span>
            </div>
        </article>

        <!-- CTA -->
        <div class="cta-box">
            <h2>Ready to Analyze?</h2>
            <p>Join thousands of users who rely on QuickFinCalc for accurate, private financial planning — completely free.</p>
            <a href="/" class="cta-btn">Start Calculating Now →</a>
        </div>

    </div>
</Layout>