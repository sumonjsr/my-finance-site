---
import Layout from '../layouts/Layout.astro';

const title = "Contact Us | FinanceHub Pro";
const description = "Get in touch with the FinanceHub team. Report a calculator issue, suggest a new tool, or ask any question about our free financial calculators.";
---

<Layout title={title} description={description}>
    <style>
        /* Contact Page Specific Styles */
        .hero { background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%); padding: 70px 20px; text-align: center; color: white; }
        .hero h1 { font-size: 2.6rem; font-weight: 800; margin: 0 0 14px; font-family: 'Inter', sans-serif; }
        .hero p { opacity: 0.88; font-size: 1.1rem; margin: 0 auto; max-width: 500px; }

        .container { max-width: 1000px; margin: 50px auto; padding: 0 20px; display: grid; grid-template-columns: 1fr 1.6fr; gap: 28px; }
        @media (max-width: 700px) { .container { grid-template-columns: 1fr; } }

        .info-col { display: flex; flex-direction: column; gap: 20px; }
        .info-card { background: white; border-radius: 18px; padding: 28px; border: 1px solid #e2e8f0; box-shadow: 0 4px 16px rgba(0,0,0,0.03); }
        .info-card h2 { color: #1e3a8a; font-size: 1.15rem; margin: 0 0 14px; }
        .info-card p { font-size: 0.9rem; color: #64748b; margin-bottom: 10px; }

        .contact-item { display: flex; align-items: flex-start; gap: 14px; padding: 14px 0; border-bottom: 1px solid #e2e8f0; }
        .contact-icon { width: 40px; height: 40px; border-radius: 10px; background: #f0f9ff; border: 1px solid #bfdbfe; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; flex-shrink: 0; }
        .contact-label { font-size: 0.8rem; color: #64748b; font-weight: 600; text-transform: uppercase; }
        .contact-value { font-size: 0.95rem; color: #1e293b; font-weight: 500; }
        .response-badge { display: inline-flex; align-items: center; gap: 6px; background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; border-radius: 999px; padding: 6px 14px; font-size: 0.825rem; font-weight: 600; }

        .form-card { background: white; border-radius: 20px; padding: 40px; border: 1px solid #e2e8f0; box-shadow: 0 4px 16px rgba(0,0,0,0.03); }
        .form-group { margin-bottom: 20px; }
        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
        @media (max-width: 500px) { .form-row { grid-template-columns: 1fr; } }

        label { display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 7px; }
        input, select, textarea { width: 100%; padding: 13px 16px; border: 1.5px solid #cbd5e1; border-radius: 10px; outline: none; transition: 0.2s; }
        input:focus, select:focus, textarea:focus { border-color: #2563eb; box-shadow: 0 0 0 4px rgba(37,99,235,0.08); }

        .submit-btn { width: 100%; padding: 16px; background: #1e3a8a; color: white; border: none; border-radius: 12px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .submit-btn:hover { background: #2563eb; transform: translateY(-2px); }

        .success-msg { display: none; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 14px; padding: 24px; text-align: center; color: #166534; }

        .faq-section { max-width: 1000px; margin: 0 auto 50px; padding: 0 20px; }
        .faq-item { background: white; border: 1px solid #e2e8f0; border-radius: 14px; margin-bottom: 12px; overflow: hidden; }
        .faq-question { padding: 18px 22px; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between; }
        .faq-answer { padding: 0 22px; max-height: 0; overflow: hidden; transition: 0.3s ease; color: #64748b; font-size: 0.9rem; }
        .faq-answer.open { max-height: 200px; padding-bottom: 18px; }
    </style>

    <section class="hero">
        <h1>Get in Touch</h1>
        <p>Questions, suggestions, or found a bug? We read every message and respond promptly.</p>
    </section>

    <div class="container">
        <aside class="info-col">
            <div class="info-card">
                <h2>Contact Information</h2>
                <div class="contact-item">
                    <div class="contact-icon">👤</div>
                    <div>
                        <div class="contact-label">Maintained By</div>
                        <div class="contact-value">Md. Merajul Islam</div>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">⏱️</div>
                    <div>
                        <div class="contact-label">Response Time</div>
                        <div class="contact-value">
                            <span class="response-badge">✅ Usually within 48 hours</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="info-card">
                <h2>Important Note</h2>
                <p>FinanceHub calculators provide estimates for informational purposes only. We do not provide personalized financial advice.</p>
            </div>
        </aside>

        <div class="form-card">
            <h2>Send Us a Message</h2>
            <form id="contactForm">
                <div class="form-row">
                    <div>
                        <label for="firstName">First Name *</label>
                        <input type="text" id="firstName" required />
                    </div>
                    <div>
                        <label for="lastName">Last Name</label>
                        <input type="text" id="lastName" />
                    </div>
                </div>
                <div class="form-group">
                    <label for="email">Email Address *</label>
                    <input type="email" id="email" required />
                </div>
                <div class="form-group">
                    <label for="topic">Topic *</label>
                    <select id="topic" required>
                        <option value="" disabled selected>Select a topic...</option>
                        <option value="bug">🐛 Report a Bug</option>
                        <option value="suggest">💡 Suggest a New Calculator</option>
                        <option value="formula">📐 Question About a Formula</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="message">Message *</label>
                    <textarea id="message" required maxlength="1000"></textarea>
                    <div style="text-align: right; font-size: 0.8rem; color: #64748b;" id="charCount">0 / 1000</div>
                </div>
                <button type="submit" class="submit-btn" id="submitBtn">Send Message →</button>
            </form>

            <div class="success-msg" id="successMsg">
                <h3>✅ Message Sent!</h3>
                <p>Thank you for reaching out. We will get back to you soon.</p>
            </div>
        </div>
    </div>

    <div class="faq-section">
        <h2>Frequently Asked Questions</h2>
        <div class="faq-item">
            <div class="faq-question" id="faq1">
                Are all FinanceHub calculators really free?
                <span>▾</span>
            </div>
            <div class="faq-answer" id="ans1">
                Yes — every single calculator on FinanceHub is completely free to use with no hidden fees.
            </div>
        </div>
        <div class="faq-item">
            <div class="faq-question" id="faq2">
                Is my financial data safe?
                <span>▾</span>
            </div>
            <div class="faq-answer" id="ans2">
                Absolutely. All calculations run locally in your browser. Your data never leaves your device.
            </div>
        </div>
    </div>

    <script is:inline>
        // Character counter
        const msgArea = document.getElementById('message');
        const charCount = document.getElementById('charCount');
        msgArea?.addEventListener('input', () => {
            charCount.textContent = `${msgArea.value.length} / 1000`;
        });

        // Form submit
        document.getElementById('contactForm')?.addEventListener('submit', (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.textContent = 'Sending...';
            setTimeout(() => {
                document.getElementById('contactForm').style.display = 'none';
                document.getElementById('successMsg').style.display = 'block';
            }, 800);
        });

        // Simple FAQ Toggle
        document.querySelectorAll('.faq-question').forEach(q => {
            q.addEventListener('click', () => {
                const ans = q.nextElementSibling;
                ans.classList.toggle('open');
            });
        });
    </script>
</Layout>