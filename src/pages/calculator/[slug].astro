---
import Layout from '../../layouts/Layout.astro';
import calculators from '../../../calculators.json';

export async function getStaticPaths() {
  return calculators.map((calc) => ({
    params: { slug: calc.slug },
    props: { calc },
  }));
}

const { calc } = Astro.props;

if (!calc) {
  return Astro.redirect('/404');
}

// SEO ডেটা সেটআপ
const seoTitle = calc.seo?.title || `${calc.name} | QuickFinCalc`;
const seoDescription = calc.seo?.meta_description || calc.description;
---

<Layout title={seoTitle} description={seoDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(calc.seo.schema)} />
  
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> / <a href="/calculator">Calculators</a> / {calc.name}
    </nav>

    <div class="calc-box">
      <h1>{calc.seo.h1 || calc.name}</h1>
      <p class="desc-top">{calc.description}</p>

      <div class="input-group">
        <label for="v1">{calc.label1}</label>
        <input type="number" id="v1" class="calc-input" placeholder="0.00" step="any" />

        {calc.label2 && (
          <label for="v2">{calc.label2}</label>
          <input type="number" id="v2" class="calc-input" placeholder="0.00" step="any" />
        )}

        {calc.label3 && (
          <label for="v3">{calc.label3}</label>
          <input type="number" id="v3" class="calc-input" placeholder="0.00" step="any" />
        )}

        <button id="calcBtn">Calculate Now</button>
        <div id="result" class="result-box"></div>
        
        <div id="chartWrapper" style="display:none; margin-top: 35px; background: #fff; padding: 25px; border-radius: 20px; border: 1px solid #e2e8f0;">
          <h3 style="text-align:center; font-size:1.1rem; color:#1e3a8a; margin-bottom:15px; font-family:'Crimson Pro', serif;">Visual Breakdown</h3>
          <canvas id="resultChart"></canvas>
        </div>
      </div>
    </div>

    <div class="rich-content">
      <div class="content-section">
        <h2>{calc.seo.h2_structure?.[0] || `What is ${calc.name}?`}</h2>
        <p>{calc.what_is}</p>
      </div>
      
      <div class="content-section">
        <h2>{calc.seo.h2_structure?.[1] || "Who Should Use This Tool?"}</h2>
        <p>{calc.who_use}</p>
      </div>

      <div class="content-section">
        <h2>{calc.seo.h2_structure?.[2] || "How to Use"}</h2>
        <p style="white-space: pre-line;">{calc.how_to_use}</p>
      </div>

      <div class="content-section">
        <h2>{calc.seo.h2_structure?.[3] || "Understanding Your Results"}</h2>
        <p>{calc.how_to_read}</p>
      </div>

      <div class="pro-tip">
        <strong>💡 Pro Tip:</strong> {calc.pro_tip}
      </div>

      {calc.seo.faqs && (
        <div class="content-section faq-section" style="margin-top: 40px;">
          <h2>{calc.seo.h2_structure?.[4] || "Frequently Asked Questions"}</h2>
          {calc.seo.faqs.map((faq) => (
            <div class="faq-item">
              <p class="faq-q"><strong>Q: {faq.question}</strong></p>
              <p class="faq-a">A: {faq.answer}</p>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <style>
    .container { max-width: 900px; margin: 0 auto; padding: 40px 20px; }
    .breadcrumb { margin-bottom: 20px; font-size: 0.9rem; color: #64748b; }
    .breadcrumb a { color: #1e3a8a; text-decoration: none; font-weight: 600; }
    .calc-box { background: #ffffff; padding: 45px; border-radius: 24px; box-shadow: 0 10px 40px rgba(0,0,0,0.04); border: 1px solid #e2e8f0; margin-bottom: 40px; }
    h1 { color: #1e3a8a; text-align: center; font-size: 2.5rem; font-family: 'Crimson Pro', serif; margin-bottom: 15px; font-weight: 800; }
    .desc-top { text-align: center; color: #475569; margin-bottom: 35px; font-size: 1.15rem; max-width: 600px; margin-inline: auto; }
    .input-group { max-width: 480px; margin: 0 auto; }
    label { display: block; font-weight: 700; margin-bottom: 10px; color: #1e293b; }
    .calc-input { width: 100%; padding: 16px; margin-bottom: 25px; border: 2px solid #cbd5e1; border-radius: 12px; font-size: 1.1rem; background: #f8fafc; }
    button { width: 100%; padding: 18px; background: #1e3a8a; color: white; border: none; border-radius: 12px; font-weight: 800; cursor: pointer; font-size: 1.2rem; transition: 0.2s; }
    button:hover { background: #0f172a; }
    .result-box { margin-top: 30px; padding: 30px; border-radius: 16px; background: #f0fdf4; color: #166534; font-weight: 800; display: none; text-align: center; border: 2px dashed #22c55e; font-size: 1.4rem; line-height: 1.6; }
    .rich-content { background: white; padding: 50px; border-radius: 24px; border: 1px solid #e2e8f0; line-height: 1.8; color: #334155; }
    .content-section { margin-bottom: 35px; }
    .rich-content h2 { color: #1e3a8a; font-family: 'Crimson Pro', serif; margin-bottom: 15px; font-size: 2rem; border-bottom: 2px solid #f1f5f9; padding-bottom: 10px; }
    .pro-tip { background: #fffbeb; padding: 30px; border-radius: 16px; margin-top: 40px; border-left: 6px solid #d4a373; color: #92400e; }
    .faq-item { margin-bottom: 20px; padding-bottom: 15px; border-bottom: 1px solid #f1f5f9; }
    .faq-q { color: #1e293b; font-size: 1.1rem; margin-bottom: 5px; }
    .faq-a { color: #475569; }
  </style>

  <script>
    import Chart from 'chart.js/auto';

    let myChart = null;
    function updateChart(labels, data) {
      const ctx = document.getElementById('resultChart');
      document.getElementById('chartWrapper').style.display = 'block';

      if (myChart) { myChart.destroy(); }

      myChart = new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: data,
            backgroundColor: ['#1e3a8a', '#d4a373', '#64748b'],
            hoverOffset: 15,
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: { position: 'bottom', labels: { padding: 20, font: { size: 12, weight: 'bold' } } }
          }
        }
      });
    }

    const btn = document.getElementById('calcBtn');
    const resDiv = document.getElementById('result');
    const fmt = (num) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(num);
    const pct = (num) => isFinite(num) ? num.toFixed(2) + '%' : '0.00%';

    btn.addEventListener('click', () => {
      const v1 = parseFloat(document.getElementById('v1')?.value || 0);
      const v2 = parseFloat(document.getElementById('v2')?.value || 0);
      const v3 = parseFloat(document.getElementById('v3')?.value || 0);
      
      const formula = window.currentFormula;
      const calcName = window.currentName;
      
      let out = "";
      let cLabels = [];
      let cData = [];

      switch (formula) {
        case 'loan':
          const r = (v2 / 12) / 100;
          const emi = r > 0 ? (v1 * r * Math.pow(1 + r, v3)) / (Math.pow(1 + r, v3) - 1) : v1 / v3;
          const totalInt = (emi * v3) - v1;
          out = `Monthly Payment: ${fmt(emi)} <br/> Total Repayment: ${fmt(emi * v3)}`;
          cLabels = ['Principal Amount', 'Total Interest'];
          cData = [v1, totalInt];
          break;

        case 'roi':
          const profitRoi = v1 - v2;
          out = `ROI: ${pct((profitRoi / v2) * 100)} <br/> Profit: ${fmt(profitRoi)}`;
          cLabels = ['Investment Cost', 'Net Profit'];
          cData = [v2, profitRoi > 0 ? profitRoi : 0];
          break;

        case 'runway':
          const burn = v2 - v3;
          if (burn <= 0) {
            out = `Runway: Infinite <br/> Status: Profitable`;
            cLabels = ['Cash in Hand', 'Monthly Revenue'];
            cData = [v1, v3];
          } else {
            out = `Runway: ${(v1 / burn).toFixed(1)} Months <br/> Burn: ${fmt(burn)}`;
            cLabels = ['Remaining Cash', 'Monthly Net Burn'];
            cData = [v1, burn];
          }
          break;

        case 'margin':
          const netMargin = v1 - v2;
          out = `Margin: ${pct((netMargin / v1) * 100)} <br/> Profit: ${fmt(netMargin)}`;
          cLabels = ['Total Cost', 'Net Profit'];
          cData = [v2, netMargin > 0 ? netMargin : 0];
          break;

        case 'stock':
          const stockProfit = (v2 - v1) * v3;
          out = `Gain/Loss: ${fmt(stockProfit)} <br/> Return: ${pct(((v2-v1)/v1)*100)}`;
          cLabels = ['Total Investment', 'Total Gain'];
          cData = [v1 * v3, stockProfit > 0 ? stockProfit : 0];
          break;

        case 'tax':
          const taxAmt = v1 * (v2 / 100);
          out = `Tax Amount: ${fmt(taxAmt)} <br/> Total: ${fmt(v1 + taxAmt)}`;
          cLabels = ['Base Price', 'Tax Amount'];
          cData = [v1, taxAmt];
          break;

        case 'compound':
          const compoundTotal = v1 * Math.pow(1 + (v2 / 100) / 12, 12 * v3);
          const compInt = compoundTotal - v1;
          out = `Future Value: ${fmt(compoundTotal)} <br/> Interest Earned: ${fmt(compInt)}`;
          cLabels = ['Initial Deposit', 'Total Interest'];
          cData = [v1, compInt];
          break;

        case 'dividend':
          out = `Yield: ${pct((v1 / v2) * 100)} <br/> Annual Payout: ${fmt(v1 * v3)}`;
          cLabels = ['Stock Price', 'Annual Dividend'];
          cData = [v2, v1 * v3];
          break;

        case 'ratio':
          const ratioVal = v1 / v2;
          out = `Ratio: ${ratioVal.toFixed(2)}`;
          cLabels = ['Numerator', 'Denominator'];
          cData = [v1, v2];
          break;

        default:
          out = `Result: ${fmt(v1 * v2)}`;
          cLabels = ['Value 1', 'Value 2'];
          cData = [v1, v2];
      }

      resDiv.innerHTML = out;
      resDiv.style.display = 'block';
      if (cData.length > 0) updateChart(cLabels, cData);
      resDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  </script>

  <script define:vars={{ f: calc.formula, n: calc.name }}>
    window.currentFormula = f;
    window.currentName = n;
  </script>
</Layout>