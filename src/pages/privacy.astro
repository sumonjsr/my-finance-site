---
const title = "Privacy Policy | FinanceHub";
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
        :root { --primary: #1e3a8a; --secondary: #2563eb; --text-dark: #1e293b; --text-light: #64748b; --border: #e2e8f0; }
        body { font-family: 'Inter', sans-serif; background: #f8fafc; margin: 0; padding: 0; }
        header { background: white; padding: 25px 0; border-bottom: 1px solid var(--border); text-align: center; }
        .logo { font-size: 2rem; font-weight: 800; color: var(--primary); text-decoration: none; }
        .logo span { color: var(--secondary); }
        .container { max-width: 800px; margin: 60px auto; padding: 40px; background: white; border-radius: 20px; border: 1px solid var(--border); }
        h2 { color: var(--primary); margin-top: 30px; }
        footer { background: #0f172a; color: #94a3b8; padding: 40px; text-align: center; margin-top: 80px; }
    </style>
</head>
<body>
    <header><a href="/" class="logo">Finance<span>Hub</span></a></header>
    <main class="container">
        <h1>Privacy Policy</h1>
        <p>Effective Date: April 2026</p>
        <h2>1. Data Protection</h2>
        <p>FinanceHub does not store or transmit any financial data entered into our calculators. All calculations are processed on your local device.</p>
        <h2>2. Cookies</h2>
        <p>We use essential cookies to ensure the site works correctly and to analyze visitor traffic via Google Analytics to improve our services.</p>
    </main>
    <footer>&copy; 2026 FinanceHub. Designed by Md Merajul Islam.</footer>
</body>
</html>