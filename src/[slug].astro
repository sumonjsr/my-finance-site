---
import calculators from '../../calculators.json';

export function getStaticPaths() {
  return calculators.map((calc) => ({
    params: { slug: calc.slug },
    props: { calc },
  }));
}

const { calc } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{calc.name} | FinanceHub</title>
    <style>
        body { font-family: 'Inter', sans-serif; background: #f1f5f9; margin: 0; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        .nav { background: #1e40af; color: white; padding: 20px; width: 100%; text-align: center; font-weight: bold; margin-bottom: 60px; }
        .calculator-card { background: white; padding: 40px; border-radius: 20px; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.1); width: 100%; max-width: 450px; border: 1px solid #e2e8f0; }
        h1 { color: #1e3a8a; font-size: 1.8rem; margin-bottom: 10px; text-align: center; }
        .desc { color: #64748b; text-align: center; margin-bottom: 35px; font-size: 1rem; line-height: 1.5; }
        label { display: block; margin-bottom: 10px; font-weight: 600; color: #334155; font-size: 0.9rem; }
        input { width: 100%; padding: 14px; margin-bottom: 25px; border: 2px solid #e2e8f0; border-radius: 10px; box-sizing: border-box; font-size: 1rem; transition: 0.2s; }
        input:focus { border-color: #2563eb; outline: none; box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1); }
        button { width: 100%; padding: 16px; background: #2563eb; color: white; border: none; border-radius: 10px; cursor: pointer; font-weight: bold; font-size: 1.1rem; transition: 0.3s; }
        button:hover { background: #1d4ed8; transform: translateY(-2px); }
        .footer-nav { margin-top: 30px; }
        .back-btn { text-decoration: none; color: #64748b; font-size: 0.9rem; font-weight: 500; transition: 0.2s; }
        .back-btn:hover { color: #1e40af; }
    </style>
</head>
<body>
    <div class="nav">FinanceHub.bd</div>
    <div class="calculator-card">
        <h1>{calc.name}</h1>
        <p class="desc">{calc.description}</p>
        
        <label>{calc.label1}</label>
        <input type="number" id="input1" placeholder="0.00" />
        
        <label>{calc.label2}</label>
        <input type="number" id="input2" placeholder="0.00" />
        
        <button onclick="alert('Calculation logic for ' + document.title + ' is being integrated.')">Run Analysis</button>
        
        <div class="footer-nav">
            <center><a href="/" class="back-btn">&larr; Back to Dashboard</a></center>
        </div>
    </div>
</body>
</html>