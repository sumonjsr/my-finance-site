---
// Try this path first. If it fails, remove one set of '../'
import calculators from '../../calculators.json';

export async function getStaticPaths() {
  return calculators.map((calc) => ({
    params: { slug: calc.slug },
    props: { calc },
  }));
}

const { calc } = Astro.props;
---
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>{calc.name} | FinanceHub</title>
    <style>
        body { font-family: sans-serif; padding: 50px; background: #f4f4f9; text-align: center; }
        .card { background: white; padding: 40px; border-radius: 15px; display: inline-block; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        input { display: block; margin: 10px auto; padding: 10px; width: 200px; }
        button { padding: 10px 20px; background: #1e40af; color: white; border: none; border-radius: 5px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="card">
        <h1>{calc.name}</h1>
        <p>{calc.description}</p>
        <label>{calc.label1}</label>
        <input type="number" />
        <label>{calc.label2}</label>
        <input type="number" />
        <br/>
        <button>Calculate</button>
        <br/><br/>
        <a href="/">Back to Home</a>
    </div>
</body>
</html>