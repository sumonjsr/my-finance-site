# Redirect trailing slashes to non-trailing
/calculator/*/ https://quickfincalc.com/:splat 301
/articles/*/ https://quickfincalc.com/:splat 301

# Redirect all .html files to non-.html versions
/calculator/*:splat.html /calculator/:splat 301
/articles/*:splat.html /articles/:splat 301

# Catch-all for any .html in root
/*:splat.html /:splat 301